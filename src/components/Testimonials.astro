---
import { TESTIMONIALS } from '@data/site';
import SectionHeading from './SectionHeading.astro';

export interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
}

const {
  eyebrow = 'Trust signals',
  title = 'What our clients say',
  description = 'Real stories from home-service businesses growing with PrintFast.',
} = Astro.props;
---
<section class="section bg-ink-50/60">
  <div class="container-pf">
    <SectionHeading
      eyebrow={eyebrow}
      title={title}
      description={description}
    />

    <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {TESTIMONIALS.map((t) => (
        <figure class="card p-7 sm:p-8 flex flex-col gap-5" data-reveal>
          <div class="flex items-center gap-1 text-accent-500">
            {Array.from({ length: t.rating }).map(() => (
              <i class="fa-solid fa-star text-sm"></i>
            ))}
          </div>
          <blockquote class="text-ink-800 leading-relaxed">
            <i class="fa-solid fa-quote-left text-brand-200 mr-2"></i>
            {t.quote}
          </blockquote>
          <figcaption class="mt-auto flex items-center gap-3 pt-4 border-t border-ink-100">
            <span class="grid h-10 w-10 place-items-center rounded-full bg-brand-100 text-brand-700 font-bold">
              {t.name.charAt(0)}
            </span>
            <span>
              <span class="block text-sm font-semibold text-ink-900">{t.name}</span>
              <span class="block text-xs text-ink-500">{t.role}</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
