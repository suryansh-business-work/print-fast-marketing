---
// Accessibility settings drawer.
// Persists user preferences to localStorage and applies CSS classes / data attrs to <html>.
---

<!-- Floating launcher button (fixed bottom-right) -->
<button
  type="button"
  data-a11y-open
  aria-label="Open accessibility settings"
  aria-controls="a11y-drawer"
  aria-expanded="false"
  class="fixed bottom-5 right-5 z-[60] grid h-12 w-12 place-items-center rounded-full bg-brand-700 text-white shadow-glow ring-2 ring-white hover:bg-brand-800 focus:outline-none focus-visible:ring-4 focus-visible:ring-brand-400 transition-transform hover:scale-105"
>
  <i class="fa-solid fa-universal-access text-xl" aria-hidden="true"></i>
</button>

<!-- Backdrop -->
<div
  data-a11y-backdrop
  class="fixed inset-0 z-[70] bg-ink-900/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
></div>

<!-- Drawer panel -->
<aside
  id="a11y-drawer"
  data-a11y-drawer
  role="dialog"
  aria-modal="true"
  aria-labelledby="a11y-title"
  tabindex="-1"
  class="fixed top-0 right-0 z-[80] h-full w-full max-w-sm translate-x-full bg-white shadow-2xl transition-transform duration-300 ease-out flex flex-col focus:outline-none"
>
  <header class="flex items-center justify-between px-6 py-5 border-b border-ink-100 bg-gradient-to-r from-brand-700 to-brand-800 text-white">
    <div>
      <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-white/70">Accessibility</p>
      <h2 id="a11y-title" class="text-lg font-display font-bold">Display & reading</h2>
    </div>
    <button
      type="button"
      data-a11y-close
      aria-label="Close accessibility settings"
      class="grid h-9 w-9 place-items-center rounded-full bg-white/10 hover:bg-white/20 ring-1 ring-white/20"
    >
      <i class="fa-solid fa-xmark" aria-hidden="true"></i>
    </button>
  </header>

  <div class="flex-1 overflow-y-auto px-6 py-6 space-y-7 text-ink-800">
    <!-- Text size -->
    <section>
      <div class="flex items-center justify-between">
        <h3 class="text-sm font-semibold text-ink-900">
          <i class="fa-solid fa-text-height text-brand-600 mr-2" aria-hidden="true"></i>Text size
        </h3>
        <span data-a11y-size-label class="text-xs text-ink-500">100%</span>
      </div>
      <div class="mt-3 grid grid-cols-4 gap-2" role="group" aria-label="Text size">
        <button type="button" class="a11y-chip" data-a11y-size="90">A−</button>
        <button type="button" class="a11y-chip" data-a11y-size="100">A</button>
        <button type="button" class="a11y-chip" data-a11y-size="115">A+</button>
        <button type="button" class="a11y-chip" data-a11y-size="130">A++</button>
      </div>
    </section>

    <!-- Contrast / theme -->
    <section>
      <h3 class="text-sm font-semibold text-ink-900">
        <i class="fa-solid fa-circle-half-stroke text-brand-600 mr-2" aria-hidden="true"></i>Contrast
      </h3>
      <div class="mt-3 grid grid-cols-3 gap-2" role="group" aria-label="Contrast mode">
        <button type="button" class="a11y-chip" data-a11y-contrast="default">Default</button>
        <button type="button" class="a11y-chip" data-a11y-contrast="high">High</button>
        <button type="button" class="a11y-chip" data-a11y-contrast="dark">Dark</button>
      </div>
    </section>

    <!-- Toggles -->
    <section class="space-y-3">
      <h3 class="text-sm font-semibold text-ink-900">
        <i class="fa-solid fa-sliders text-brand-600 mr-2" aria-hidden="true"></i>Reading helpers
      </h3>

      <label class="a11y-toggle">
        <span>
          <i class="fa-solid fa-book-open mr-2 text-ink-500" aria-hidden="true"></i>
          Dyslexia-friendly font
        </span>
        <input type="checkbox" data-a11y-toggle="dyslexic" class="sr-only peer" />
        <span class="a11y-switch"></span>
      </label>

      <label class="a11y-toggle">
        <span>
          <i class="fa-solid fa-arrows-left-right-to-line mr-2 text-ink-500" aria-hidden="true"></i>
          Increase letter spacing
        </span>
        <input type="checkbox" data-a11y-toggle="spacing" class="sr-only peer" />
        <span class="a11y-switch"></span>
      </label>

      <label class="a11y-toggle">
        <span>
          <i class="fa-solid fa-link mr-2 text-ink-500" aria-hidden="true"></i>
          Highlight links
        </span>
        <input type="checkbox" data-a11y-toggle="links" class="sr-only peer" />
        <span class="a11y-switch"></span>
      </label>

      <label class="a11y-toggle">
        <span>
          <i class="fa-solid fa-pause mr-2 text-ink-500" aria-hidden="true"></i>
          Reduce motion
        </span>
        <input type="checkbox" data-a11y-toggle="motion" class="sr-only peer" />
        <span class="a11y-switch"></span>
      </label>

      <label class="a11y-toggle">
        <span>
          <i class="fa-solid fa-image mr-2 text-ink-500" aria-hidden="true"></i>
          Hide images
        </span>
        <input type="checkbox" data-a11y-toggle="hide-images" class="sr-only peer" />
        <span class="a11y-switch"></span>
      </label>

      <label class="a11y-toggle">
        <span>
          <i class="fa-solid fa-i-cursor mr-2 text-ink-500" aria-hidden="true"></i>
          Big cursor
        </span>
        <input type="checkbox" data-a11y-toggle="cursor" class="sr-only peer" />
        <span class="a11y-switch"></span>
      </label>
    </section>

    <!-- Quick links -->
    <section>
      <h3 class="text-sm font-semibold text-ink-900">
        <i class="fa-solid fa-compass text-brand-600 mr-2" aria-hidden="true"></i>Jump to
      </h3>
      <div class="mt-3 grid grid-cols-2 gap-2 text-sm">
        <a href="#main" class="a11y-chip text-center">Main content</a>
        <a href="#contact" class="a11y-chip text-center">Contact form</a>
      </div>
    </section>
  </div>

  <footer class="px-6 py-4 border-t border-ink-100 bg-ink-50 flex items-center justify-between">
    <button
      type="button"
      data-a11y-reset
      class="text-sm font-semibold text-ink-700 hover:text-brand-700"
    >
      <i class="fa-solid fa-rotate-left mr-1" aria-hidden="true"></i> Reset all
    </button>
    <p class="text-xs text-ink-500">Settings saved on this device</p>
  </footer>
</aside>

<style is:global>
  /* Drawer chip + toggle styles */
  .a11y-chip {
    @apply rounded-lg border border-ink-200 bg-white px-3 py-2 text-sm font-semibold text-ink-700 hover:border-brand-500 hover:text-brand-700 transition-colors;
  }
  .a11y-chip[aria-pressed="true"] {
    @apply border-brand-500 bg-brand-50 text-brand-700;
  }
  .a11y-toggle {
    @apply flex items-center justify-between gap-3 cursor-pointer rounded-xl border border-ink-100 px-4 py-3 hover:border-brand-200 hover:bg-brand-50/40 transition-colors;
  }
  .a11y-switch {
    @apply relative h-6 w-11 rounded-full bg-ink-200 transition-colors flex-shrink-0;
  }
  .a11y-switch::after {
    content: '';
    @apply absolute top-0.5 left-0.5 h-5 w-5 rounded-full bg-white shadow transition-transform;
  }
  .peer:checked ~ .a11y-switch {
    @apply bg-brand-600;
  }
  .peer:checked ~ .a11y-switch::after {
    transform: translateX(1.25rem);
  }
  .peer:focus-visible ~ .a11y-switch {
    @apply ring-2 ring-brand-400 ring-offset-2;
  }

  /* === Applied accessibility modes (set via data attrs on <html>) === */
  html[data-a11y-dyslexic="true"] body,
  html[data-a11y-dyslexic="true"] body * {
    font-family: 'Comic Sans MS', 'OpenDyslexic', 'Atkinson Hyperlegible', system-ui, sans-serif !important;
    letter-spacing: 0.02em;
  }
  html[data-a11y-spacing="true"] body {
    letter-spacing: 0.06em !important;
    word-spacing: 0.12em !important;
    line-height: 1.8 !important;
  }
  html[data-a11y-links="true"] a:not(.btn):not(.btn-primary):not(.btn-outline):not(.btn-ghost):not(.btn-accent) {
    text-decoration: underline !important;
    text-underline-offset: 3px;
    text-decoration-thickness: 2px;
    color: #44881d !important;
    background: rgba(255, 235, 59, 0.35);
    padding: 0 2px;
    border-radius: 2px;
  }
  html[data-a11y-motion="true"] *,
  html[data-a11y-motion="true"] *::before,
  html[data-a11y-motion="true"] *::after {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
    scroll-behavior: auto !important;
  }
  html[data-a11y-hide-images="true"] img,
  html[data-a11y-hide-images="true"] svg:not([data-a11y-keep]),
  html[data-a11y-hide-images="true"] picture {
    visibility: hidden !important;
  }
  html[data-a11y-cursor="true"],
  html[data-a11y-cursor="true"] * {
    cursor: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='40' height='40' viewBox='0 0 40 40'><path d='M4 4 L4 32 L12 24 L18 36 L23 33 L17 22 L28 22 Z' fill='black' stroke='white' stroke-width='2'/></svg>") 4 4, auto !important;
  }

  /* Contrast modes */
  html[data-a11y-contrast="high"] body {
    background: #ffffff !important;
    color: #000000 !important;
  }
  html[data-a11y-contrast="high"] body * {
    color: #000000 !important;
    border-color: #000000 !important;
  }
  html[data-a11y-contrast="high"] a {
    color: #0000ee !important;
    text-decoration: underline !important;
  }
  html[data-a11y-contrast="high"] .gradient-text {
    background: none !important;
    -webkit-text-fill-color: #000 !important;
    color: #000 !important;
  }

  html[data-a11y-contrast="dark"] body {
    background: #0b1020 !important;
    color: #f6f7f9 !important;
  }
  html[data-a11y-contrast="dark"] header,
  html[data-a11y-contrast="dark"] .card,
  html[data-a11y-contrast="dark"] .card-hover,
  html[data-a11y-contrast="dark"] section {
    background-color: #0b1020 !important;
    color: #f6f7f9 !important;
  }
  html[data-a11y-contrast="dark"] .card,
  html[data-a11y-contrast="dark"] .card-hover {
    background-color: #161c33 !important;
    border-color: #2a3258 !important;
  }
  html[data-a11y-contrast="dark"] .text-ink-900,
  html[data-a11y-contrast="dark"] .text-ink-800,
  html[data-a11y-contrast="dark"] .text-ink-700 {
    color: #f6f7f9 !important;
  }
  html[data-a11y-contrast="dark"] .text-ink-600,
  html[data-a11y-contrast="dark"] .text-ink-500 {
    color: #b1b8c5 !important;
  }
</style>

<script is:inline>
  (function () {
    const STORAGE_KEY = 'pf-a11y-prefs-v1';
    const html = document.documentElement;
    const drawer = document.querySelector('[data-a11y-drawer]');
    const backdrop = document.querySelector('[data-a11y-backdrop]');
    const openBtn = document.querySelector('[data-a11y-open]');
    const closeBtn = document.querySelector('[data-a11y-close]');
    const resetBtn = document.querySelector('[data-a11y-reset]');
    const sizeLabel = document.querySelector('[data-a11y-size-label]');
    const sizeBtns = document.querySelectorAll('[data-a11y-size]');
    const contrastBtns = document.querySelectorAll('[data-a11y-contrast]');
    const toggles = document.querySelectorAll('[data-a11y-toggle]');

    const defaults = {
      size: 100,
      contrast: 'default',
      dyslexic: false,
      spacing: false,
      links: false,
      motion: false,
      'hide-images': false,
      cursor: false,
    };

    let prefs = { ...defaults };
    try {
      const stored = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      prefs = { ...defaults, ...stored };
    } catch (_) { /* ignore */ }

    function apply() {
      html.style.fontSize = prefs.size + '%';
      if (sizeLabel) sizeLabel.textContent = prefs.size + '%';
      sizeBtns.forEach((b) => {
        b.setAttribute('aria-pressed', String(Number(b.dataset.a11ySize) === prefs.size));
      });

      if (prefs.contrast === 'default') html.removeAttribute('data-a11y-contrast');
      else html.setAttribute('data-a11y-contrast', prefs.contrast);
      contrastBtns.forEach((b) => {
        b.setAttribute('aria-pressed', String(b.dataset.a11yContrast === prefs.contrast));
      });

      ['dyslexic', 'spacing', 'links', 'motion', 'hide-images', 'cursor'].forEach((key) => {
        if (prefs[key]) html.setAttribute('data-a11y-' + key, 'true');
        else html.removeAttribute('data-a11y-' + key);
      });
      toggles.forEach((t) => {
        const k = t.dataset.a11yToggle;
        t.checked = !!prefs[k];
      });
    }

    function save() {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(prefs)); } catch (_) { /* ignore */ }
    }

    function openDrawer() {
      drawer.classList.remove('translate-x-full');
      backdrop.classList.remove('opacity-0', 'pointer-events-none');
      openBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      setTimeout(() => drawer.focus(), 50);
    }
    function closeDrawer() {
      drawer.classList.add('translate-x-full');
      backdrop.classList.add('opacity-0', 'pointer-events-none');
      openBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      openBtn.focus();
    }

    openBtn?.addEventListener('click', openDrawer);
    closeBtn?.addEventListener('click', closeDrawer);
    backdrop?.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !drawer.classList.contains('translate-x-full')) closeDrawer();
    });

    sizeBtns.forEach((b) => b.addEventListener('click', () => {
      prefs.size = Number(b.dataset.a11ySize);
      apply(); save();
    }));
    contrastBtns.forEach((b) => b.addEventListener('click', () => {
      prefs.contrast = b.dataset.a11yContrast;
      apply(); save();
    }));
    toggles.forEach((t) => t.addEventListener('change', () => {
      prefs[t.dataset.a11yToggle] = t.checked;
      apply(); save();
    }));
    resetBtn?.addEventListener('click', () => {
      prefs = { ...defaults };
      apply(); save();
    });

    apply();
  })();
</script>
