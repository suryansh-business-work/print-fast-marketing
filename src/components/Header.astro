---
import { NAV_LINKS, SITE } from '@data/site';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  const clean = href.replace(/\/$/, '');
  return currentPath === clean || currentPath.startsWith(clean + '/');
}
---

<header class="sticky top-0 z-50 border-b border-ink-100/70 bg-white/85 backdrop-blur supports-[backdrop-filter]:bg-white/70 dark:border-ink-800/60 dark:bg-ink-950/80 dark:supports-[backdrop-filter]:bg-ink-950/60">
  <!-- Top accent bar (logo's rainbow gradient) -->
  <div aria-hidden="true" class="h-[3px] w-full bg-spectrum"></div>

  <div class="container-pf flex h-16 items-center justify-between gap-4 lg:h-20 lg:gap-8">
    <a href="/" class="flex items-center gap-2 group" aria-label={`${SITE.fullName} home`}>
      <img
        src={SITE.logoLight}
        alt={`${SITE.fullName} logo`}
        width="180"
        height="48"
        decoding="async"
        fetchpriority="high"
        class="block dark:hidden h-9 sm:h-10 lg:h-12 w-auto object-contain transition-transform group-hover:scale-[1.02]"
      />
      <img
        src={SITE.logoDark}
        alt={`${SITE.fullName} logo`}
        width="180"
        height="48"
        decoding="async"
        class="hidden dark:block h-9 sm:h-10 lg:h-12 w-auto object-contain transition-transform group-hover:scale-[1.02]"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Primary">
      {NAV_LINKS.map((link) => {
        const active = isActive(link.href);
        if (link.children?.length) {
          return (
            <div class="relative group" data-mega>
              <button
                type="button"
                class:list={[
                  'inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-sm font-medium transition-colors',
                  active
                    ? 'bg-brand-50 text-brand-700'
                    : 'text-ink-700 hover:text-brand-700 hover:bg-ink-50',
                ]}
                aria-haspopup="true"
                aria-expanded="false"
                data-mega-toggle
              >
                {link.label}
                <i class="fa-solid fa-chevron-down text-[10px] transition-transform group-hover:rotate-180" aria-hidden="true"></i>
              </button>

              <!-- Mega panel -->
              <div
                class="invisible opacity-0 translate-y-2 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 focus-within:visible focus-within:opacity-100 focus-within:translate-y-0 transition-all duration-200 absolute left-1/2 top-full -translate-x-1/2 pt-3 z-50"
                data-mega-panel
              >
                <div class="w-[min(92vw,820px)] rounded-2xl border border-ink-100 bg-white shadow-2xl overflow-hidden">
                  <div class="grid lg:grid-cols-[1.4fr,1fr]">
                    <div class="p-6 grid sm:grid-cols-2 gap-2">
                      {link.children.map((c) => (
                        <a
                          href={c.href}
                          class="group/item flex items-start gap-3 rounded-xl p-3 hover:bg-brand-50 transition-colors"
                        >
                          <span class="grid h-10 w-10 place-items-center rounded-lg bg-brand-50 text-brand-600 group-hover/item:bg-brand-600 group-hover/item:text-white transition-colors flex-shrink-0">
                            <i class:list={['fa-solid', c.icon]} aria-hidden="true"></i>
                          </span>
                          <span class="min-w-0">
                            <span class="block text-sm font-semibold text-ink-900 group-hover/item:text-brand-700">{c.label}</span>
                            {c.description && (
                              <span class="block text-xs text-ink-500 mt-0.5 leading-snug">{c.description}</span>
                            )}
                          </span>
                        </a>
                      ))}
                    </div>
                    {link.featured && (
                      <aside class="relative p-6 bg-gradient-to-br from-ink-900 via-ink-800 to-ink-900 text-white overflow-hidden">
                        <div aria-hidden="true" class="absolute -top-10 -right-10 h-40 w-40 rounded-full bg-brand-500/25 blur-2xl"></div>
                        <div aria-hidden="true" class="absolute -bottom-12 -left-8 h-32 w-32 rounded-full bg-accent-500/15 blur-2xl"></div>
                        <p class="relative text-[11px] uppercase tracking-[0.2em] text-brand-300">Featured</p>
                        <h3 class="relative mt-2 text-lg font-display font-bold text-white">{link.featured.title}</h3>
                        <p class="relative mt-1.5 text-sm text-ink-200">{link.featured.description}</p>
                        <a href={link.featured.href} class="relative mt-4 inline-flex items-center gap-2 rounded-full bg-brand-500 px-4 py-2 text-sm font-semibold text-ink-900 hover:bg-brand-400 transition-colors shadow-glow">
                          {link.featured.cta} <i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i>
                        </a>
                      </aside>
                    )}
                  </div>
                </div>
              </div>
            </div>
          );
        }
        return (
          <a
            href={link.href}
            class:list={[
              'rounded-full px-4 py-2 text-sm font-medium transition-colors',
              active
                ? 'bg-brand-50 text-brand-700'
                : 'text-ink-700 hover:text-brand-700 hover:bg-ink-50',
            ]}
          >
            {link.label}
          </a>
        );
      })}
    </nav>

    <div class="hidden lg:flex items-center gap-3">
      <button
        type="button"
        data-search-open
        aria-label="Search"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full ring-1 ring-ink-200 text-ink-700 hover:bg-ink-50 hover:text-brand-700 dark:ring-ink-700 dark:text-ink-200 dark:hover:bg-ink-800 dark:hover:text-brand-400 transition-colors"
      >
        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
      </button>
      <a href={SITE.phoneHref} class="text-sm font-semibold text-ink-700 hover:text-brand-700 dark:text-ink-200 dark:hover:text-brand-400">
        <i class="fa-solid fa-phone text-brand-600"></i>
        <span class="ml-2">{SITE.phone}</span>
      </a>
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full ring-1 ring-ink-200 text-ink-700 hover:bg-ink-50 hover:text-brand-700 dark:ring-ink-700 dark:text-ink-200 dark:hover:bg-ink-800 dark:hover:text-brand-400 transition-colors"
        aria-label="Toggle dark mode"
        data-theme-toggle
      >
        <i class="fa-solid fa-sun hidden dark:inline-block" aria-hidden="true"></i>
        <i class="fa-solid fa-moon dark:hidden" aria-hidden="true"></i>
      </button>
      <a href="/contact-us/" class="btn-primary">
        Get a Quote <i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i>
      </a>
    </div>

    <div class="flex items-center gap-2 lg:hidden">
      <button
        type="button"
        data-search-open
        aria-label="Search"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg ring-1 ring-ink-200 text-ink-700 dark:ring-ink-700 dark:text-ink-200"
      >
        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
      </button>
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg ring-1 ring-ink-200 text-ink-700 dark:ring-ink-700 dark:text-ink-200"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-toggle
      >
        <i class="fa-solid fa-bars" data-icon-open></i>
        <i class="fa-solid fa-xmark hidden" data-icon-close></i>
      </button>
    </div>
  </div>

  <!-- Mobile mega menu (accordion) -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-ink-100 bg-white max-h-[calc(100vh-4rem)] overflow-y-auto"
    data-menu-panel
  >
    <nav class="container-pf py-4 flex flex-col gap-1" aria-label="Mobile primary">
      {NAV_LINKS.map((link) => {
        if (link.children?.length) {
          return (
            <details class="group rounded-xl border border-ink-100 open:bg-ink-50/60" data-mobile-mega>
              <summary class="flex cursor-pointer list-none items-center justify-between rounded-xl px-4 py-3 text-base font-semibold text-ink-900">
                <span>{link.label}</span>
                <i class="fa-solid fa-chevron-down text-xs text-ink-500 transition-transform group-open:rotate-180" aria-hidden="true"></i>
              </summary>
              <div class="px-2 pb-3 space-y-1">
                {link.children.map((c) => (
                  <a href={c.href} class="flex items-start gap-3 rounded-lg px-3 py-2.5 hover:bg-white">
                    <span class="grid h-9 w-9 place-items-center rounded-md bg-brand-50 text-brand-600 flex-shrink-0">
                      <i class:list={['fa-solid', c.icon]} aria-hidden="true"></i>
                    </span>
                    <span class="min-w-0">
                      <span class="block text-sm font-semibold text-ink-900">{c.label}</span>
                      {c.description && <span class="block text-xs text-ink-500 mt-0.5">{c.description}</span>}
                    </span>
                  </a>
                ))}
                {link.featured && (
                  <a href={link.featured.href} class="mx-2 mt-2 flex items-center justify-between rounded-lg bg-gradient-to-r from-ink-900 to-ink-800 px-4 py-3 text-white ring-1 ring-brand-500/30">
                    <span>
                      <span class="block text-sm font-semibold">{link.featured.title}</span>
                      <span class="block text-xs text-brand-300">{link.featured.cta}</span>
                    </span>
                    <i class="fa-solid fa-arrow-right text-xs text-brand-400" aria-hidden="true"></i>
                  </a>
                )}
              </div>
            </details>
          );
        }
        return (
          <a
            href={link.href}
            class="rounded-lg px-4 py-3 text-base font-medium text-ink-800 hover:bg-ink-50 hover:text-brand-700"
          >
            {link.label}
          </a>
        );
      })}
      <div class="mt-3 grid grid-cols-1 gap-2">
        <button
          type="button"
          class="btn-outline justify-center"
          aria-label="Toggle dark mode"
          data-theme-toggle
        >
          <i class="fa-solid fa-moon dark:hidden" aria-hidden="true"></i>
          <i class="fa-solid fa-sun hidden dark:inline-block" aria-hidden="true"></i>
          <span class="dark:hidden">Dark mode</span>
          <span class="hidden dark:inline">Light mode</span>
        </button>
        <a href={SITE.phoneHref} class="btn-outline justify-center">
          <i class="fa-solid fa-phone"></i> {SITE.phone}
        </a>
        <a href="/contact-us/" class="btn-primary justify-center">
          Get a Quote
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  // Mobile drawer toggle
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const panel = document.querySelector<HTMLDivElement>('[data-menu-panel]');
  const iconOpen = document.querySelector<HTMLElement>('[data-icon-open]');
  const iconClose = document.querySelector<HTMLElement>('[data-icon-close]');

  toggle?.addEventListener('click', () => {
    const isOpen = panel?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });

  // Close mobile menu when navigating
  panel?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      panel.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    })
  );

  // Desktop mega: click toggles aria-expanded for keyboard accessibility (hover handles visuals)
  document.querySelectorAll<HTMLButtonElement>('[data-mega-toggle]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
    });
  });

  // Theme toggle (light/dark) — persisted in localStorage
  const setTheme = (mode: 'light' | 'dark') => {
    document.documentElement.classList.toggle('dark', mode === 'dark');
    try { localStorage.setItem('pf-theme', mode); } catch (e) {}
  };
  document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      setTheme(isDark ? 'light' : 'dark');
    });
  });
</script>

