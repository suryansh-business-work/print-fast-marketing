---
export interface Props {
  src: string;
  class?: string;
  ariaLabel?: string;
  loop?: boolean;
  autoplay?: boolean;
  speed?: number;
  background?: string;
}
const {
  src,
  class: className = '',
  ariaLabel,
  loop = true,
  autoplay = true,
  speed = 1,
  background = 'transparent',
} = Astro.props;
---
<div class:list={['relative', className]} role={ariaLabel ? 'img' : undefined} aria-label={ariaLabel}>
  <lottie-player
    src={src}
    background={background}
    speed={String(speed)}
    {...(loop ? { loop: '' } : {})}
    {...(autoplay ? { autoplay: '' } : {})}
    style="width: 100%; height: 100%;"
  ></lottie-player>
</div>

<!-- Lazy-load Lottie player only on pages that actually use this component -->
<script src="https://unpkg.com/@lottiefiles/lottie-player@2.0.8/dist/lottie-player.js" defer></script>
