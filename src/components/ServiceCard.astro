---
export interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
  cta?: string;
  number?: string | number;
}
const { icon, title, description, href, cta = 'Learn more', number } = Astro.props;
const Tag = href ? 'a' : 'div';
---
<Tag
  href={href}
  class="card-hover group relative flex flex-col p-7 sm:p-8 h-full"
  data-reveal
>
  {number && (
    <span class="absolute top-5 right-6 text-5xl font-display font-extrabold text-brand-50 group-hover:text-brand-100 transition-colors">
      {number}
    </span>
  )}
  <span class="grid h-12 w-12 place-items-center rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 text-white shadow-soft">
    <i class:list={['fa-solid', icon]}></i>
  </span>
  <h3 class="mt-5 text-xl font-bold text-ink-900">{title}</h3>
  <p class="mt-3 text-ink-600 leading-relaxed flex-1">{description}</p>
  {href && (
    <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand-700 group-hover:gap-3 transition-all">
      {cta} <i class="fa-solid fa-arrow-right text-xs"></i>
    </span>
  )}
</Tag>
