---
import { TRUST_LOGOS } from '@data/site';
---
<section class="py-12 border-y border-ink-100 bg-white">
  <div class="container-pf">
    <p class="text-center text-xs font-semibold uppercase tracking-[0.22em] text-ink-500">
      Trusted by 500+ home-service brands across the U.S.
    </p>

    <div class="pf-marquee mt-8">
      <div class="pf-marquee__track">
        {[...TRUST_LOGOS, ...TRUST_LOGOS].map((logo) => (
          <span class="flex items-center gap-3 text-ink-400 hover:text-ink-700 transition-colors whitespace-nowrap">
            <i class="fa-solid fa-circle-nodes text-brand-500"></i>
            <span class="font-display text-lg font-bold tracking-wide">{logo}</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
