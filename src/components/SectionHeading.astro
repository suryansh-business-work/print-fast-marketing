---
export interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, description, align = 'center' } = Astro.props;
---
<div class:list={[
  'max-w-3xl',
  align === 'center' ? 'mx-auto text-center' : '',
]} data-reveal>
  {eyebrow && (
    <p class="eyebrow">
      <i class="fa-solid fa-bolt text-brand-600"></i> {eyebrow}
    </p>
  )}
  <h2 class="heading-lg mt-4">{title}</h2>
  {description && <p class="lead mt-5">{description}</p>}
</div>
