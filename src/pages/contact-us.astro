---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
import ContactForm from '@components/ContactForm.astro';
import CheckoutReadyCTA from '@components/CheckoutReadyCTA.tsx';
import Lottie from '@components/Lottie.astro';
import OfficeMap from '@components/OfficeMap.tsx';
import { SITE, TEAM } from '@data/site';

const channels = [
  {
    icon: 'fa-phone',
    label: 'Call us',
    value: SITE.phone,
    href: SITE.phoneHref,
    sub: 'Mon–Fri · 8 AM – 5 PM ET',
  },
  {
    icon: 'fa-envelope',
    label: 'Sales',
    value: 'orders@print-fast.com',
    href: 'mailto:orders@print-fast.com',
    sub: 'Replies within 1 business day',
  },
  {
    icon: 'fa-location-dot',
    label: 'Visit us',
    value: 'Middlesex, NJ',
    href: `https://www.google.com/maps/dir/?api=1&destination=${SITE.address.lat},${SITE.address.lng}`,
    sub: '100 Blackford Ave., 08846',
  },
  {
    icon: 'fa-calendar-check',
    label: 'Book a strategy call',
    value: 'Pick a time',
    href: '#contact-form',
    sub: 'Free 30-min consultation',
  },
];

const departments = [
  { icon: 'fa-rocket', label: 'New business / Sales',  email: 'orders@print-fast.com', desc: 'Pricing, onboarding, free reviews.' },
  { icon: 'fa-headset', label: 'Client support', email: 'mark@print-fast.com', desc: 'Existing client questions & requests.' },
  { icon: 'fa-newspaper', label: 'Press & media', email: 'bill@print-fast.com', desc: 'Interview, partnership and PR enquiries.' },
];

const faqs = [
  { q: 'How fast can you start?', a: 'Most engagements kick off within 5 business days of signing — strategy in week one, content in week two.' },
  { q: 'Do you require contracts?', a: 'No long-term lock-ins. We earn the relationship monthly with measurable progress.' },
  { q: 'Which industries do you serve?', a: 'We focus on home-service brands — HVAC, plumbing, electrical, roofing, landscaping, cleaning, pest control and pool/spa.' },
  { q: 'Do you work nationally?', a: 'Yes — we serve clients in all 50 states, from single-truck operators to multi-location franchises.' },
];
---

<BaseLayout
  title="Contact Us"
  description="Talk to PrintFast — get pricing, book a strategy call, or claim your free Digital Review. We respond within 1 business day."
  keywords={['contact PrintFast', 'home service marketing contact', 'PrintFast phone', 'request a quote marketing agency']}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Contact', href: '/contact-us/' },
  ]}
  faqs={faqs.map((f) => ({ question: f.q, answer: f.a }))}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact PrintFast Digital Marketing',
    url: `${SITE.url}/contact-us/`,
  }}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-hero-radial">
    <div class="container-pf grid lg:grid-cols-12 gap-10 items-center py-16 sm:py-20 lg:py-24">
      <div class="lg:col-span-7 min-w-0" data-reveal>
        <p class="eyebrow"><i class="fa-solid fa-bolt text-brand-600"></i> Contact Us</p>
        <h1 class="heading-xl mt-4">Let's get the <span class="gradient-text">phone ringing.</span></h1>
        <p class="lead mt-5 max-w-2xl">
          Whether you want pricing, a free Digital Review, or just an honest second opinion on your marketing — we're easy to reach.
        </p>
        <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm text-ink-600">
          <p class="inline-flex items-center gap-2"><i class="fa-solid fa-check text-brand-600"></i> Reply within 1 business day</p>
          <p class="inline-flex items-center gap-2"><i class="fa-solid fa-check text-brand-600"></i> No-obligation conversations</p>
          <p class="inline-flex items-center gap-2"><i class="fa-solid fa-check text-brand-600"></i> US-based team</p>
        </div>
      </div>
      <div class="lg:col-span-5 min-w-0" data-reveal>
        <div class="relative aspect-square max-w-md mx-auto">
          <div aria-hidden="true" class="absolute inset-0 rounded-[2rem] bg-gradient-to-br from-brand-500/15 to-spectrum-yellow/20 blur-2xl"></div>
          <div class="relative h-full w-full rounded-[2rem] bg-white ring-1 ring-ink-100 shadow-soft overflow-hidden">
            <Lottie
              src="https://assets10.lottiefiles.com/packages/lf20_u25cckyh.json"
              ariaLabel="Customer service contact animation"
              class="h-full w-full"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact channels -->
  <section class="section-tight">
    <div class="container-pf">
      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {channels.map((c) => (
          <li>
            <a href={c.href} class="card-hover p-6 block h-full">
              <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600 text-lg">
                <i class:list={['fa-solid', c.icon]} aria-hidden="true"></i>
              </span>
              <p class="mt-5 text-xs font-semibold uppercase tracking-[0.18em] text-ink-500">{c.label}</p>
              <p class="mt-1 text-lg font-bold text-ink-900">{c.value}</p>
              <p class="mt-1 text-sm text-ink-500">{c.sub}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Form + sidebar -->
  <section class="section scroll-mt-28" id="contact-form">
    <div class="container-pf grid lg:grid-cols-12 gap-10 items-start">
      <div class="lg:col-span-7 min-w-0">
        <ContactForm />
        <div class="mt-6">
          <CheckoutReadyCTA client:load />
        </div>
      </div>

      <aside class="lg:col-span-5 min-w-0 space-y-6">
        <!-- Departments -->
        <div class="card p-6 sm:p-8">
          <h3 class="heading-md text-2xl">Find the right inbox</h3>
          <p class="mt-2 text-ink-600 text-sm">For faster routing, email the team that fits your need.</p>
          <ul class="mt-6 space-y-4">
            {departments.map((d) => (
              <li class="flex items-start gap-4">
                <span class="grid h-10 w-10 place-items-center rounded-lg bg-brand-50 text-brand-600 flex-shrink-0">
                  <i class:list={['fa-solid', d.icon]} aria-hidden="true"></i>
                </span>
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-ink-900">{d.label}</p>
                  <a href={`mailto:${d.email}`} class="text-sm text-brand-700 hover:text-brand-800 break-all">{d.email}</a>
                  <p class="text-xs text-ink-500 mt-0.5">{d.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <!-- Hours / location -->
        <div class="card p-6 sm:p-8 bg-ink-900 text-white relative overflow-hidden">
          <span aria-hidden="true" class="absolute -top-16 -right-16 h-44 w-44 rounded-full bg-brand-600/40 blur-3xl"></span>
          <h3 class="text-xl font-bold relative">Visit our office</h3>
          <p class="mt-2 text-white/80 text-sm relative">{SITE.hours}</p>
          <div class="mt-6 grid grid-cols-2 gap-4 relative text-sm">
            <div class="col-span-2">
              <p class="text-white/60 uppercase text-[11px] tracking-wider">{SITE.address.company}</p>
              <p class="font-semibold">{SITE.address.street}</p>
              <p class="font-semibold">{SITE.address.city}, {SITE.address.state} {SITE.address.zip}</p>
            </div>
            <div>
              <p class="text-white/60 uppercase text-[11px] tracking-wider">Phone</p>
              <a href={SITE.phoneHref} class="font-semibold text-white hover:text-brand-300">{SITE.phone}</a>
            </div>
            <div>
              <p class="text-white/60 uppercase text-[11px] tracking-wider">Sales</p>
              <a href="mailto:orders@print-fast.com" class="font-semibold text-white hover:text-brand-300 break-all">orders@print-fast.com</a>
            </div>
          </div>
        </div>

        <!-- Leadership -->
        <div class="card p-6 sm:p-8">
          <h3 class="heading-md text-2xl">Talk to our leadership</h3>
          <p class="mt-2 text-ink-600 text-sm">Need a direct line? Our leadership team is one email away.</p>
          <ul class="mt-6 space-y-4">
            {TEAM.map((member) => (
              <li class="flex items-start gap-4">
                <span class="grid h-10 w-10 place-items-center rounded-lg bg-brand-50 text-brand-600 flex-shrink-0">
                  <i class:list={['fa-solid', member.icon]} aria-hidden="true"></i>
                </span>
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-ink-900">{member.name}</p>
                  <p class="text-xs text-ink-500 mt-0.5">{member.role}</p>
                  <a href={`mailto:${member.email}`} class="text-sm text-brand-700 hover:text-brand-800 break-all">{member.email}</a>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <!-- Map -->
  <section class="section-tight">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Find us"
        title="Stop by our New Jersey HQ"
        description="100 Blackford Ave., Middlesex, NJ 08846 — about 35 minutes from Newark Liberty International."
      />
      <div class="mt-10 grid lg:grid-cols-3 gap-6 items-stretch">
        <div class="relative z-0 lg:col-span-2 rounded-3xl overflow-hidden ring-1 ring-ink-100 shadow-soft h-[420px] sm:h-[480px] bg-ink-50">
          <OfficeMap
            client:only="react"
            lat={SITE.address.lat}
            lng={SITE.address.lng}
            company={SITE.address.company}
            address={SITE.address.full}
            phone={SITE.phone}
            phoneHref={SITE.phoneHref}
          />
        </div>
        <div class="card p-6 sm:p-8 flex flex-col gap-5">
          <div>
            <p class="eyebrow"><i class="fa-solid fa-location-dot text-brand-600"></i> Office</p>
            <h3 class="mt-3 text-xl font-display font-bold text-ink-900">{SITE.address.company}</h3>
            <p class="mt-2 text-ink-600 text-sm leading-relaxed">
              {SITE.address.street}<br />
              {SITE.address.city}, {SITE.address.state} {SITE.address.zip}<br />
              {SITE.address.country}
            </p>
          </div>
          <ul class="space-y-3 text-sm">
            <li class="flex items-center gap-3">
              <span class="grid h-9 w-9 place-items-center rounded-lg bg-brand-50 text-brand-600 flex-shrink-0"><i class="fa-solid fa-phone text-xs"></i></span>
              <a href={SITE.phoneHref} class="font-semibold text-ink-900 hover:text-brand-700">{SITE.phone}</a>
            </li>
            <li class="flex items-center gap-3">
              <span class="grid h-9 w-9 place-items-center rounded-lg bg-brand-50 text-brand-600 flex-shrink-0"><i class="fa-solid fa-envelope text-xs"></i></span>
              <a href="mailto:orders@print-fast.com" class="font-semibold text-ink-900 hover:text-brand-700 break-all">orders@print-fast.com</a>
            </li>
            <li class="flex items-center gap-3">
              <span class="grid h-9 w-9 place-items-center rounded-lg bg-brand-50 text-brand-600 flex-shrink-0"><i class="fa-solid fa-clock text-xs"></i></span>
              <span class="text-ink-700">{SITE.hours}</span>
            </li>
          </ul>
          <a
            href={`https://www.google.com/maps/dir/?api=1&destination=${SITE.address.lat},${SITE.address.lng}`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary justify-center mt-auto"
          >
            Get directions <i class="fa-solid fa-arrow-right text-xs"></i>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="FAQs"
        title="Quick answers before you reach out"
      />
      <div class="mt-10 max-w-3xl mx-auto space-y-3">
        {faqs.map((f) => (
          <details class="group card p-0 overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer list-none p-5 sm:p-6 text-left">
              <span class="text-base sm:text-lg font-semibold text-ink-900">{f.q}</span>
              <span class="grid h-8 w-8 place-items-center rounded-full bg-brand-50 text-brand-600 ml-4 flex-shrink-0 transition-transform group-open:rotate-45">
                <i class="fa-solid fa-plus text-xs" aria-hidden="true"></i>
              </span>
            </summary>
            <p class="px-5 sm:px-6 pb-5 sm:pb-6 -mt-2 text-ink-600 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
