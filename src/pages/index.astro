---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Stats from '@components/Stats.astro';
import SectionHeading from '@components/SectionHeading.astro';
import ServiceCard from '@components/ServiceCard.astro';
import FeatureGrid from '@components/FeatureGrid.astro';
import Testimonials from '@components/Testimonials.astro';
import CTA from '@components/CTA.astro';
import ContactForm from '@components/ContactForm.astro';
import ClientLogos from '@components/ClientLogos.astro';
import { SERVICES } from '@data/site';

const whyUs = [
  { icon: 'fa-trophy', title: 'Trades-only expertise', description: "35+ years of focused digital marketing work with HVAC, plumbing, electrical, roofing, lawn care, cleaning and home service contractors across the U.S. — we speak the trades, we don't just serve them." },
  { icon: 'fa-chart-line', title: 'Performance focus', description: 'We obsess over qualified contractor leads, inbound calls and booked jobs — not impressions, likes or follower counts. Every campaign is measured against real revenue impact.' },
  { icon: 'fa-handshake', title: 'No lock-in', description: "We earn the relationship every month. Cancel anytime with a 30-day notice and keep every asset we've built — your ad accounts, website, content and data are yours. No lock-in, no proprietary systems." },
  { icon: 'fa-bolt', title: 'Fast execution', description: 'Our home service marketing team ships live campaigns within days of kickoff — not weeks of onboarding calls. New PPC accounts launch in under 48 hours. New websites go live in under 30 days.' },
  { icon: 'fa-comments', title: 'Dedicated strategist', description: 'Every PrintFast client gets a named, senior strategist who knows your local market, your service area, your seasonality and your revenue goals — not a rotating junior account manager.' },
  { icon: 'fa-lock', title: 'Transparent reporting', description: "Live KPI dashboards updated in real time, monthly executive performance reviews and zero black-box metrics. You always know exactly where your marketing budget is going and what it's returning." },
];
---

<BaseLayout
  title="Home Service Marketing Agency | SEO, PPC & More | PrintFast"
  appendSiteName={false}
  description="Senior U.S. home service marketing agency — SEO, Google Ads, social media, email and websites for HVAC, plumbing, roofing and contractors. 12M+ leads generated."
  keywords={[
    'home service marketing agency',
    'home service digital marketing company',
    'contractor marketing agency',
    'HVAC marketing agency',
    'plumbing marketing agency',
    'roofing marketing agency',
    'digital marketing agency USA',
    'social media marketing services',
    'email marketing services',
    'website creation services',
    'SEO services USA',
    'pay-per-click advertising',
    'PPC management',
    'home service marketing',
    'PrintFast',
  ]}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'ProfessionalService',
    name: 'PrintFast Digital Marketing',
    image: 'https://dqj17tese79do.cloudfront.net/printfast/images/websitelogos/retailer_site_logo776.png',
    priceRange: '$$',
    areaServed: 'United States',
    aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '500' },
  }}
>
  <Hero
    eyebrow="PrintFast Digital Marketing"
    title="Home Service Marketing That Books Real Jobs — SEO, PPC, Social & More for"
    highlight="U.S. Contractors"
    description="A full-service home service digital marketing company delivering social media, email marketing, websites, SEO and Google Ads. Get more qualified calls, more booked jobs and a contractor brand your customers trust."
    primaryCta={{ label: 'Get Your Free Marketing Proposal', href: '/contact-us/' }}
    secondaryCta={{ label: 'Explore Services', href: '#services' }}
  />

  <Stats />

  <ClientLogos
    eyebrow="Our clients"
    title="Home Service Contractors Who Trust PrintFast to Grow Their Business"
    description="From single-truck HVAC operators to multi-location plumbing and roofing brands, hundreds of U.S. home service contractors rely on PrintFast for their digital marketing every month. We grow businesses at every stage — and we never work with your direct competitors."
  />

  <section id="services" class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="What we do"
        title="Digital Marketing Services Built for Home Service Contractors"
        description="A complete home service digital marketing stack tuned for the trades. Choose a single channel or combine SEO, PPC, social media, email and web — every engagement starts with a strategy call, a market audit and a clear plan tied to booked jobs."
      />

      {/* Layout: row 1 = first 3 services centered, row 2 = remaining 2 services centered. */}
      <div class="mt-14 space-y-6">
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {SERVICES.slice(0, 3).map((s) => (
            <ServiceCard
              icon={s.icon}
              title={s.title}
              description={s.description}
              href={s.href}
            />
          ))}
        </div>
        {SERVICES.length > 3 && (
          <div class="grid gap-6 sm:grid-cols-2 lg:max-w-[calc(66.6667%-1rem)] lg:mx-auto">
            {SERVICES.slice(3).map((s) => (
              <ServiceCard
                icon={s.icon}
                title={s.title}
                description={s.description}
                href={s.href}
              />
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Why PrintFast"
        title="Why Home Service Contractors Choose PrintFast Over Other Marketing Agencies"
        description="We know HVAC seasonality, the slow weeks between plumbing calls and the truck-roll math that makes roofing jobs profitable. As a specialized home service digital marketing company, we build campaigns that fit your business model — not a generic agency playbook."
      />
      <div class="mt-14">
        <FeatureGrid items={whyUs} columns={3} />
      </div>
    </div>
  </section>

  <Testimonials />

  <CTA
    eyebrow="Free strategy session"
    title="Get a Free Home Service Marketing Strategy Session — No Commitment Required"
    description="Tell us your revenue goals and current marketing gaps — our home service digital marketing team will respond with a tailored proposal covering the right mix of social media, email, SEO, Google Ads and web design within 1-2 business days. No long-term commitment to get started."
    primaryCta={{ label: 'Get My Free Marketing Proposal', href: '/contact-us/' }}
    secondaryCta={{ label: 'Talk to a strategist', href: '/contact-us/#contact-form' }}
  />

  <section id="contact" class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Connect with us"
        title="Tell us about your goals"
        description="We're here to help — drop a few details below and we'll reach out within one business day."
      />
      <div class="mt-12 grid gap-8 lg:grid-cols-5">
        <div class="lg:col-span-3">
          <ContactForm />
        </div>
        <aside class="lg:col-span-2 space-y-5">
          <div class="card p-7">
            <h3 class="font-bold text-lg">Why customers stay</h3>
            <ul class="check-list mt-4 space-y-3 text-sm">
              <li>Senior strategist on every account</li>
              <li>Live KPI dashboards, no fluff reports</li>
              <li>You own all content, ad accounts and assets</li>
              <li>Trades-only — we won't work with your competitor</li>
            </ul>
          </div>
          <div class="card p-7 outline outline-1 outline-brand-300 text-black">
            <h3 class="font-bold text-lg text-black">Prefer to talk?</h3>
            <p class="mt-2 text-black/80 text-sm">Mon–Fri · 8 AM – 5 PM ET</p>
            <a href="tel:800-810-4818" class="pt-5 block font-semibold text-brand-700 hover:text-brand-800">
              <i class="fa-solid fa-phone"></i> 800-810-4818
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
