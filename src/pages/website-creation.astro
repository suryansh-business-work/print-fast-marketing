  { icon: 'fa-universal-access', title: 'WCAG 2.2 AA accessibility', description: 'Every ADA compliant website for contractors we build meets WCAG 2.2 AA accessibility standards — including keyboard navigation and screen-reader compatibility. This protects your home service business from the rising wave of U.S. ADA web lawsuits and keeps your site usable by every potential customer.' },
  { icon: 'fa-mobile-screen',  title: 'Mobile-first design',      description: 'Over 60% of homeowners searching for HVAC, plumbing, and electrical services are on a mobile device. We design every mobile website for HVAC companies and other trades for the smallest screen first, then scale up, so you capture every call, regardless of how they find you.' },
  { icon: 'fa-magnifying-glass-chart', title: 'SEO-grade architecture', description: 'Clean URLs, semantic HTML, schema.org LocalBusiness and Service markup, and automated sitemap submission — all built into your home service website from day one. This is the technical foundation behind a website that ranks on Google for home service businesses in HVAC, plumbing, and electrical markets.' },
  { icon: 'fa-bullseye',       title: 'Conversion-first design',  description: 'Every page on your contractor website has one clear primary action — call, book, or request a quote. Sticky phone numbers, prominent CTAs, and lead capture forms are strategically placed to convert browsing homeowners into real service bookings.' },
  { icon: 'fa-shield-halved',  title: 'Secure & compliant',       description: "HTTPS, secure headers, CCPA/state privacy banners, and a modern tech stack that passes any security review. Your home service website is protected from day one — and your customers' data is handled correctly under U.S. privacy law." },
];

