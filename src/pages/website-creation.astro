---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import SectionHeading from '@components/SectionHeading.astro';
import FeatureGrid from '@components/FeatureGrid.astro';
import PricingCard from '@components/PricingCard.astro';
import Testimonials from '@components/Testimonials.astro';
import CTA from '@components/CTA.astro';
import ContactForm from '@components/ContactForm.astro';
import ClientLogos from '@components/ClientLogos.astro';
import { SITE } from '@data/site';

const principles = [
  { icon: 'fa-gauge-high',     title: 'Speed by default',         description: 'Sub-3-second load times, 80+ Lighthouse score, and Core Web Vitals "Good" — standard on every home service website we ship. Faster sites rank higher and convert more homeowners browsing on mobile.' },
  { icon: 'fa-universal-access', title: 'WCAG 2.2 AA accessibility', description: 'Every ADA compliant website for contractors we build meets WCAG 2.2 AA accessibility standards — including keyboard navigation and screen-reader compatibility. This protects your home service business from the rising wave of U.S. ADA web lawsuits and keeps your site usable by every potential customer.' },
  { icon: 'fa-mobile-screen',  title: 'Mobile-first design',      description: 'Over 60% of homeowners searching for HVAC, plumbing, and electrical services are on a mobile device. We design every mobile website for HVAC companies and other trades for the smallest screen first, then scale up, so you capture every call, regardless of how they find you.' },
  { icon: 'fa-magnifying-glass-chart', title: 'SEO-grade architecture', description: 'Clean URLs, semantic HTML, schema.org LocalBusiness and Service markup, and automated sitemap submission — all built into your home service website from day one. This is the technical foundation behind a website that ranks on Google for home service businesses in HVAC, plumbing, and electrical markets.' },
  { icon: 'fa-bullseye',       title: 'Conversion-first design',  description: 'Every page on your contractor website has one clear primary action — call, book, or request a quote. Sticky phone numbers, prominent CTAs, and lead capture forms are strategically placed to convert browsing homeowners into real service bookings.' },
  { icon: 'fa-shield-halved',  title: 'Secure & compliant',       description: "HTTPS, secure headers, CCPA/state privacy banners, and a modern tech stack that passes any security review. Your home service website is protected from day one — and your customers' data is handled correctly under U.S. privacy law." },
];

const stack = [
  { name: 'Astro',       icon: 'fa-rocket',       desc: 'Ideal for home service marketing websites that prioritize page speed and local SEO rankings — extremely fast load times with minimal overhead.' },
  { name: 'Next.js',     icon: 'fa-react',        desc: 'Best for multi-location home service companies needing dynamic service-area pages, customer portals, or booking integrations.' },
  { name: 'WordPress',   icon: 'fa-wordpress',    desc: 'Perfect for home service businesses with an in-house coordinator who needs to update blog posts, seasonal promotions, and service pages without a developer.' },
  { name: 'Shopify',     icon: 'fa-bag-shopping', desc: 'For home service businesses selling products, maintenance kits, or equipment online alongside their service offerings.' },
  { name: 'Webflow',     icon: 'fa-paintbrush',   desc: 'Great for contractor companies that need a visually polished website with fast design iteration and no developer dependency for routine updates.' },
  { name: 'HubSpot CMS', icon: 'fa-cubes',        desc: 'Best for home service companies already using HubSpot CRM — keeps your website, lead tracking, email marketing, and sales pipeline in one connected platform.' },
];

const includes = [
  { icon: 'fa-pen-ruler',         title: 'Custom design system',       description: "A branded component library built around your home service company's colors, fonts, and visual identity — keeping every service page, location page, and seasonal promo consistent." },
  { icon: 'fa-code',              title: 'Hand-built code',            description: "No page builder bloat or templates. Clean, production-grade code reviewed for speed, security, and search performance — the foundation your home service website's rankings depend on." },
  { icon: 'fa-link',              title: 'Booking & CRM integrations', description: 'Native integrations with the tools home service companies actually use: ServiceTitan, Housecall Pro, Jobber, HubSpot, Salesforce, and Calendly — configured correctly so booked jobs flow directly into your dispatch system.' },
  { icon: 'fa-pen-to-square',     title: 'Easy CMS editing',         description: 'A friendly editor so your team can update copy and images without a developer.' },
  { icon: 'fa-image',             title: 'Optimized media pipeline',   description: 'Next-gen image formats, responsive sizing, and lazy loading keep your contractor website fast as you add new service photos, team headshots, and project galleries — without sacrificing Core Web Vitals scores.' },
  { icon: 'fa-chart-line',        title: 'Analytics & tag setup',      description: "GA4, Google Tag Manager, call tracking, form conversion events, and Google Search Console — fully configured before your home service website goes live, so you're measuring real leads from day one." },
  { icon: 'fa-cookie-bite',       title: 'Privacy & consent',          description: 'CCPA/CPRA-compliant cookie consent, privacy policy review, and data flow documentation — keeping your home service business legally protected under U.S. state privacy law.' },
  { icon: 'fa-life-ring',         title: 'Post-launch care',           description: 'Monthly updates, uptime monitoring, and security patching — so your home service website keeps performing long after launch, without you worrying about it.' },
];

const process = [
  { n: '01', title: 'Discover',  desc: 'We review your home service business goals, target service area, competitor websites, and existing analytics. We define what a successful contractor website looks like for your specific trade and market before a single pixel is placed.', icon: 'fa-compass' },
  { n: '02', title: 'Architect', desc: 'We map out your sitemap — service pages, locally targeted location pages, blog structure, and conversion paths. A clickable wireframe is approved before design begins, so there are no surprises mid-project.', icon: 'fa-sitemap' },
  { n: '03', title: 'Design',    desc: 'We create a custom design system and key page mockups in Figma that reflect your home service brand — colors, photography, trust signals, and local identity. Two structured revision rounds are built in so you get exactly what you envisioned.', icon: 'fa-pen-ruler' },
  { n: '04', title: 'Build',     desc: 'We write production code, configure your CMS, wire in your booking and CRM integrations (ServiceTitan, Housecall Pro, Jobber, etc.), and migrate existing content — all reviewed in a weekly staging environment before anything goes live.', icon: 'fa-code' },
  { n: '05', title: 'QA',        desc: 'Every home service website we ship is tested across browsers, real mobile devices, and screen readers — not just emulators. We check Core Web Vitals, ADA accessibility, form submissions, and call-tracking integrations before anything touches your live domain.', icon: 'fa-vial-circle-check' },
  { n: '06', title: 'Launch',    desc: 'Zero-downtime cutover, a full redirect map to protect your existing SEO rankings, Google Search Console verification, and a 30-day stabilization window. Your home service business stays visible in local search throughout the transition.', icon: 'fa-rocket' },
];

const plans = [
  {
    name: 'Essentials',
    price: '$1,499',
    period: ' one-time',
    description: 'A clean, professional starter site for small home-service businesses.',
    features: [
      '5-page website',
      'Mobile responsive design',
      '1 contact form included',
      'Home, About, Services, Promotions & Contact pages',
      'Brand-aligned design system',
      'Basic on-page SEO setup',
      '30 days of post-launch support',
    ],
    cta: { label: 'Start with Essentials', href: '/contact-us/' },
  },
  {
    name: 'Standard',
    price: '$2,999',
    period: ' one-time',
    description: 'Built for HVAC, plumbing and electrical brands ready to grow online.',
    features: [
      '10-page website',
      'Mobile responsive design',
      '1 contact form included',
      'Home, About, Services, Heating, Cooling, Plumbing, Blog & Contact pages',
      '5 locally-targeted pages',
      'Hosting, email & domain setup',
      '60 days of post-launch support',
    ],
    cta: { label: 'Choose Standard', href: '/contact-us/' },
  },
  {
    name: 'Premium',
    price: '$4,999',
    period: ' one-time',
    description: 'Our most popular package — full site, local SEO and content baked in.',
    popular: true,
    features: [
      'Full site with services pages',
      'Mobile responsive design',
      '2 contact forms included',
      'Home, About, Services, Heating, Cooling, Plumbing, 3 local, Blog & Contact pages',
      '20 locally-targeted pages',
      'Hosting, email, domain, GBP & Google Analytics setup',
      'Custom SEO-rich content',
      '1 "launch" blog article per service',
    ],
    cta: { label: 'Choose Premium', href: '/contact-us/' },
  },
  {
    name: 'AI-Enabled',
    price: '$9,999',
    period: ' one-time',
    description: 'Top-tier site with built-in AI assistant for 24/7 customer engagement.',
    features: [
      'Full site with services pages',
      'Mobile responsive design',
      '2 contact forms included',
      'Home, About, Services, Heating, Cooling, Plumbing, 8 local, Blog & Contact pages',
      '50 locally-targeted pages',
      'Hosting, email, domain, GBP & Google Analytics setup',
      'Custom SEO-rich content',
      '2 "launch" blog articles per service',
      'FAQs AI Bot — answers customer questions 24/7',
    ],
    cta: { label: 'Choose AI-Enabled', href: '/contact-us/' },
  },
];

const faqs = [
  { q: 'How long does a website take to build?',
    a: 'For home service businesses, our starter sites go live in 4–6 weeks, standard contractor sites in 8–12 weeks, and fully custom builds in 12–20 weeks. We share a week-by-week project schedule on kickoff day — no guessing, no surprises.' },
  { q: 'Do I own the website and the code?',
    a: 'Yes — always. Your home service business owns the design, code, CMS account, and domain. There is no proprietary lock-in. If you ever leave Print Fast, your entire website comes with you, including all files and login credentials.' },
  { q: 'Will the site be ADA accessible?',
    a: 'Yes. Every ADA compliant website for contractors we build targets WCAG 2.2 AA compliance — tested with axe DevTools and a manual checklist covering keyboard navigation, screen reader compatibility, and color contrast. This is critical protection for home service companies given the sharp rise in U.S. ADA web lawsuits.' },
  { q: 'Can you redesign without losing my SEO?',
    a: 'Yes. Every home service website redesign we manage includes a full content inventory, preservation of your ranked local keywords, a complete redirect map, structured data migration, and Google Search Console resubmission. Most HVAC and plumbing clients see organic traffic recover or improve within 60 days of launch.' },
  { q: 'Do you handle hosting?',
    a: 'Yes. We can host your home service website on Vercel, Netlify, or Cloudflare, or deploy to your own preferred host. Either way, you always own the hosting account — we never hold it for you.' },
  { q: 'Do you build websites specifically for HVAC, plumbing, and electrical companies?',
    a: 'Yes. Print Fast specializes in website design for home service contractors — including HVAC website design, plumbing website design, electrician website projects, roofing company website builds, pest control, and landscaping businesses. We understand service-area targeting, seasonal content strategy, and the specific pages (service, location, blog) that help home service websites rank in local Google search.' },
  { q: 'Will my new website rank on Google for local searches in my service area?',
    a: 'Every home service website we build includes on-page SEO setup, schema.org markup, locally targeted service area pages, and Google Search Console integration — so your site is positioned to rank from day one. For contractors looking to accelerate results, we also offer dedicated Local SEO services that build authority over time.' },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${SITE.url}/website-creation/#service`,
  name: 'Website Design for Home Service Companies',
  serviceType: 'Contractor website design and home service web design',
  description: 'Fast-loading, ADA-compliant, lead-generating website design for HVAC, plumbing, electrical, roofing and home service contractors across the U.S.',
  provider: { '@id': `${SITE.url}#organization` },
  areaServed: { '@type': 'Country', name: 'United States' },
  audience: {
    '@type': 'Audience',
    audienceType: 'HVAC, plumbing, electrical, roofing and home service contractors',
  },
  offers: [
    { '@type': 'Offer', name: 'Essentials', price: '1499', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Standard', price: '2999', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Premium', price: '4999', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'AI-Enabled', price: '9999', priceCurrency: 'USD' },
  ],
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE.url}#localbusiness`,
  name: SITE.fullName,
  alternateName: SITE.name,
  url: SITE.url,
  logo: new URL(SITE.logo, SITE.url).toString(),
  image: new URL(SITE.logo, SITE.url).toString(),
  telephone: SITE.phone,
  email: SITE.email,
  priceRange: '$$',
  openingHours: 'Mo-Fr 08:00-17:00',
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.state,
    postalCode: SITE.address.zip,
    addressCountry: 'US',
  },
  areaServed: { '@type': 'Country', name: 'United States' },
  sameAs: Object.values(SITE.social),
};
---

<BaseLayout
  title="Website Design for Home Service Companies | Print Fast"
  appendSiteName={false}
  description="Print Fast designs fast-loading, ADA-compliant, lead-generating websites for HVAC, plumbing, electrical, and roofing companies. Built to rank on Google and convert local homeowners. No contracts."
  keywords={[
    'website design for home service companies',
    'contractor website design',
    'home service web design agency',
    'HVAC website design',
    'plumbing website design',
    'electrician website',
    'roofing company website',
    'web design for trades',
    'local SEO website',
    'ADA compliant website for contractors',
    'mobile website for HVAC companies',
    'website that ranks on Google for home service businesses',
  ]}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Services', href: '/#services' },
    { name: 'Website Creation', href: '/website-creation/' },
  ]}
  schema={[serviceSchema, localBusinessSchema]}
>
  <Hero
    variant="service"
    eyebrow="Website Creation"
    title="Website Design for Home Service Companies That"
    highlight="Loads Fast, Ranks, and Converts."
    description="PrintFast builds custom websites for HVAC companies, plumbers, electricians, roofers, and home service contractors across the U.S. As a home service web design agency, our contractor website design process creates ADA-compliant, locally optimized sites engineered for Core Web Vitals — so they rank on Google and turn visitors into booked service calls."
    primaryCta={{ label: 'Get a Website Design Proposal', href: '/contact-us/' }}
    secondaryCta={{ label: 'See pricing', href: '#pricing' }}
    trustItems={['No long-term contracts', 'Built for HVAC, Plumbing & Home Services', 'Free website strategy call']}
  />

  <!-- Principles -->
  <section class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="What you can expect"
        title="Six Things Every Home Service Website We Build Includes — Without Exception"
        description="We build every home service contractor website to the same uncompromising standard. Whether you're a solo plumber or a multi-location HVAC franchise, these are not add-ons. They are our baseline."
      />
      <div class="mt-14">
        <FeatureGrid items={principles} columns={3} />
      </div>
    </div>
  </section>

  <!-- Stack -->
  <section class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Tech we work in"
        title="The Right Tech Stack for Your Home Service Website — We Match It to Your Goals"
        description="Not every home service business needs the same platform. We recommend the right technology based on your team size, update frequency, CRM, and long-term growth goals — never to lock you in. You own everything."
      />
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {stack.map((s) => (
          <div class="card p-6 flex gap-5" data-reveal>
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600 text-xl">
              <i class:list={[s.icon.startsWith('fa-react') || s.icon.startsWith('fa-wordpress') ? 'fa-brands' : 'fa-solid', s.icon]}></i>
            </span>
            <div>
              <h3 class="font-bold text-ink-900">{s.name}</h3>
              <p class="text-sm text-ink-600 mt-1">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="What's included"
        title="Everything Included in Your Home Service Website — Long After Launch"
        description="Every contractor website design package we deliver includes the integrations, analytics, accessibility, and post-launch care that most web agencies bill as expensive add-ons — or forget entirely. As a home service web design agency, this is our standard."
      />
      <div class="mt-14">
        <FeatureGrid items={includes} columns={4} />
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Our process"
        title="How We Build Your Home Service Website — 6 Clear Phases, Zero Surprises"
        description="We've refined our web design process specifically for home service companies — HVAC website design, plumbing website design, electrician website builds, and roofing businesses that need a site live fast, built correctly, and ranking locally. Weekly check-ins, clear milestones, and you in every decision."
      />
      <ol class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {process.map((p) => (
          <li class="card p-6" data-reveal>
            <div class="flex items-center justify-between">
              <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600">
                <i class:list={['fa-solid', p.icon]}></i>
              </span>
              <span class="text-xs font-mono text-ink-400">{p.n}</span>
            </div>
            <h3 class="mt-4 text-lg font-bold text-ink-900">{p.title}</h3>
            <p class="mt-2 text-sm text-ink-600">{p.desc}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Our Plans for Your Digital Growth"
        title="Website plans built for home-service brands"
        description="Choose any plan that fits your business. All prices in USD, one-time project fee. Optional monthly care plans available from $249/mo."
      />
      <div class="mt-14 grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
        {plans.map((p) => <PricingCard {...p} />)}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section bg-ink-50/60">
    <div class="container-pf max-w-4xl">
      <SectionHeading eyebrow="FAQs" title="Common Questions from Home Service Contractors About Our Website Design Service" />
      <div class="mt-10 space-y-3">
        {faqs.map((f) => (
          <details class="group card p-6 transition-colors hover:ring-brand-200">
            <summary class="flex cursor-pointer items-center justify-between gap-4 list-none">
              <span class="font-semibold text-ink-900">{f.q}</span>
              <i class="fa-solid fa-plus text-ink-400 group-open:rotate-45 transition-transform"></i>
            </summary>
            <p class="mt-4 text-ink-600 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Testimonials
    title="What Home Service Contractors Say About Their Print Fast Website"
    description="Real results from HVAC companies, plumbers, electricians, roofing company website clients, and home service contractors who trust Print Fast for web design for trades."
  />

  <ClientLogos
    eyebrow="Selected work"
    title="Home service brands we've built websites for"
    description="A small selection from HVAC, plumbing, electrical, roofing and contractor brands we serve."
    background="muted"
  />

  <CTA
    eyebrow="Website Design for Home Service Companies"
    title="Let's Build a Roofing Company Website, Electrician Website, or Contractor Site That Ranks."
    description="Send a few details about your trade, service area and current site. We'll come back with a tailored local SEO website proposal for web design for trades and a timeline within one business day."
    primaryCta={{ label: 'Get a Website Design Proposal', href: '/contact-us/' }}
    secondaryCta={{ label: 'Talk to a strategist', href: '#contact' }}
  />

  <section id="contact" class="section">
    <div class="container-pf max-w-4xl">
      <ContactForm
        title="Tell us about your project"
        subtitle="Share your goals, current site URL and timeline. We'll respond within one business day."
      />
    </div>
  </section>
</BaseLayout>
