<BaseLayout
  title="Website Design for Home Service Companies | PrintFast"
  appendSiteName={false}
  description="PrintFast designs fast-loading, ADA-compliant, lead-generating websites for HVAC, plumbing, electrical, and roofing companies. Built to rank on Google and convert local homeowners. No contracts."
  keywords={[
    'website design for home service companies',
    'contractor website design',
    'home service web design agency',
    'HVAC website design',
    'plumbing website design',
    'electrician website',
    'roofing company website',
    'web design for trades',
    'local SEO website',
    'ADA compliant website for contractors',
    'mobile website for HVAC companies',
    'website that ranks on Google for home service businesses',
  ]}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Services', href: '/#services' },
    { name: 'Website Creation', href: '/website-creation/' },
  ]}
  schema={[serviceSchema, localBusinessSchema]}
>
  <!-- ===================== HERO BANNER ===================== -->
  <section class="relative overflow-hidden bg-[#0f2747]">
    <span aria-hidden="true" class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-white/5 blur-3xl"></span>
    <span aria-hidden="true" class="absolute -bottom-32 -left-24 h-80 w-80 rounded-full bg-[#ED1C24]/30 blur-3xl"></span>

    <div class="container-pf relative py-16 sm:py-20 lg:py-28">
      <div class="max-w-3xl">
        <p class="inline-flex rounded-md bg-[#ED1C24] px-3 py-1.5 text-xs font-extrabold uppercase tracking-[0.18em] text-white">
          Website Creation
        </p>

        <h1 class="mt-5 font-display text-4xl font-extrabold uppercase leading-[1.03] tracking-tight text-white sm:text-5xl lg:text-6xl">
          Website Design for Home Service Companies That <span class="text-[#ED1C24]">Loads Fast, Ranks, and Converts.</span>
        </h1>

        <p class="mt-6 max-w-2xl text-sm leading-relaxed text-white/80 sm:text-base">
          PrintFast builds custom websites for HVAC companies, plumbers, electricians, roofers, and home service contractors across the U.S. As a home service web design agency, our contractor website design process creates ADA-compliant, locally optimized sites engineered for Core Web Vitals — so they rank on Google and turn visitors into booked service calls.
