---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactForm from '@components/ContactForm.astro';
import { SOCIAL_MEDIA_PLANS, getContactHref } from '@data/pricing';
import { TESTIMONIALS, CLIENT_LOGOS } from '@data/site';

const trustItems = ['Built for HVAC, Plumbing & Home Services', 'Done-for-you social media', 'Free strategy call'];

const platforms = [
  { name: 'Facebook',  icon: 'fa-facebook',  note: '#1 home service lead-gen channel for adults 35+', color: '#1877F2', bg: '#E8F3FF' },
  { name: 'Instagram', icon: 'fa-instagram', note: 'Reels & Stories for local homeowners', color: '#E4405F', bg: '#FCE9EE' },
  { name: 'TikTok',    icon: 'fa-tiktok',    note: 'Fastest-growing local discovery channel', color: '#000000', bg: '#F4F4F5' },
  { name: 'YouTube',   icon: 'fa-youtube',   note: 'Long-form trust + Shorts reach', color: '#FF0000', bg: '#FFEDEE' },
  { name: 'LinkedIn',  icon: 'fa-linkedin',  note: 'B2B, commercial & recruiting', color: '#0A66C2', bg: '#E7F1FF' },
  { name: 'Pinterest', icon: 'fa-pinterest', note: 'High-intent home & lifestyle search', color: '#BD081C', bg: '#FBECEE' },
  { name: 'X / Twitter', icon: 'fa-x-twitter', note: 'Real-time customer service', color: '#1DA1F2', bg: '#E8F5FD' },
  { name: 'Google Business', icon: 'fa-google', note: 'Posts that support local contractor rankings', color: '#4285F4', bg: '#E8F3FF' },
];

const whatYouGet = [
  { icon: 'fa-pen-fancy',           title: 'Channel-native content',  description: 'Social media for contractors built platform by platform: Reels, carousels, Shorts, Stories and posts that feel native instead of copy-pasted.' },
  { icon: 'fa-calendar-days',       title: 'Editorial calendar',       description: 'A 30-, 60- and 90-day plan tied to HVAC social media marketing seasons, plumbing offers, storm response, U.S. holidays and local service demand.' },
  { icon: 'fa-comments',            title: 'Community management',     description: 'We answer DMs, comments and reviews in your voice — helping homeowners feel heard before they call your crew.' },
  { icon: 'fa-bullhorn',            title: 'Paid social campaigns',    description: 'Facebook ads for HVAC, Meta retargeting, TikTok and YouTube campaigns with audience-by-zip targeting, lookalikes and service-area exclusions.' },
  { icon: 'fa-camera-retro',        title: 'On-site shoots (optional)', description: 'Quarterly content days where we capture technician stories, before-and-after work, fleet shots and seasonal service assets in one visit.' },
  { icon: 'fa-user-shield',         title: 'Reputation & reviews',     description: 'Active monitoring across Google, Facebook, Yelp and Nextdoor for HVAC, plumbing, roofing and electrical teams — with response templates and escalation.' },
  { icon: 'fa-people-group',        title: 'Employee advocacy',        description: 'Turn your crew into creators with simple capture kits, approval workflows and prompts built for busy home service technicians.' },
  { icon: 'fa-chart-pie',           title: 'Monthly reporting',        description: 'A home service marketing agency dashboard plus a one-page exec summary: reach, engagement, calls, leads and return on paid social spend.' },
];

const proofPoints = [
  { stat: '78%', label: 'of homeowners research home service providers on social media before calling (Source: BrightLocal Local Consumer Review Survey)' },
  { stat: '63%', label: 'of HVAC and plumbing leads check Facebook or Instagram reviews before calling a contractor (Source: LSA Insider Report)' },
  { stat: '3.4×', label: 'higher conversion rate when paid social is paired with organic for home service businesses (Source: Podium State of Online Reviews)' },
  { stat: '#1', label: 'platform for home service lead generation: Facebook for U.S. adults 35+ (Source: Meta for Business Home Services Vertical Insights)' },
];

const process = [
  { n: '01', title: 'Audit & strategy',  desc: 'We audit your current social presence, analyze local competitors in your trade, define your content pillars (trust, proof, offers, community), and build a measurable 90-day social media plan for your home service business.', icon: 'fa-compass' },
  { n: '02', title: 'Production',        desc: 'We produce trade-specific captions, branded graphics, short-form service videos, and seasonal promotional content — all reviewed and approved by you before publishing.', icon: 'fa-clapperboard' },
  { n: '03', title: 'Publish & engage',  desc: 'We schedule, publish, and reply to your customers across every platform while you stay focused on running service calls and managing your crew.', icon: 'fa-paper-plane' },
  { n: '04', title: 'Optimize & scale',  desc: "We run weekly tests on ad hooks, content formats, and audience targeting to find what drives calls in your service area. What works gets scaled; what doesn't gets cut — fast.", icon: 'fa-arrows-spin' },
];

const plans = SOCIAL_MEDIA_PLANS;

const faqs = [
  {
    q: 'Does social media actually generate leads for home service businesses?',
    a: 'Yes. But only when done consistently and with real strategy. Organic social media builds brand recognition that shortens your sales cycle. Homeowners who\'ve seen your content are more likely to call you first, trust your pricing, and refer you to neighbors. When paired with targeted advertising, the lead volume becomes measurable and scalable. We track results for every client.',
  },
  {
    q: 'How many posts per month do I actually need?',
    a: 'Minimum for local contractors is 8 to 12 posts per month across your main platforms. Below that, the algorithm stops prioritizing your page. The sweet spot for real growth is 16 to 20 posts per month mixing educational content, seasonal offers, before and after photos, and community posts. More is better, but consistency matters more than volume.',
  },
  {
    q: 'Will the content sound professional or generic?',
    a: 'Professional. Every post is written with your brand voice, your service area, and your specific trade in mind. We don\'t use the same template for an HVAC company in Chicago and an electrician in Tampa. Every piece goes through our team before it launches.',
  },
  {
    q: 'How does social media improve my Google rankings?',
    a: 'Social activity reinforces your authority to Google. More importantly, an active Google Business Profile with weekly posts and fresh photos directly impacts your position in local search results. This is one of the most underused levers in local marketing.',
  },
  {
    q: 'Which platforms should I be on?',
    a: 'For residential contractors: Facebook (primary), Instagram (brand building), and Google Business Profile (local search). For commercial work, add LinkedIn. For younger homeowners, add TikTok and Instagram Reels. YouTube is essential if you\'re serious about establishing authority.',
  },
  {
    q: 'Can I review posts before they go live?',
    a: 'Yes. Every plan includes a content approval workflow. You see it first. You approve it. It only posts when you give the green light. You\'ll never be surprised by a post that doesn\'t represent your company correctly.',
  },
  {
    q: 'Does social media actually generate leads for home service businesses?',
    a: 'Yes. But only when done consistently and with real strategy. Organic social media builds brand recognition that shortens your sales cycle. Homeowners who\'ve seen your content are more likely to call you first, trust your pricing, and refer you to neighbors. When paired with targeted advertising, the lead volume becomes measurable and scalable. We track results for every client.',
  },
  {
    q: 'How many posts per month do I actually need?',
    a: 'Minimum for local contractors is 8 to 12 posts per month across your main platforms. Below that, the algorithm stops prioritizing your page. The sweet spot for real growth is 16 to 20 posts per month mixing educational content, seasonal offers, before and after photos, and community posts. More is better, but consistency matters more than volume.',
  },
  {
    q: 'Will the content sound professional or generic?',
    a: 'Professional. Every post is written with your brand voice, your service area, and your specific trade in mind. We don\'t use the same template for an HVAC company in Chicago and an electrician in Tampa. Every piece goes through our team before it launches.',
  },
  {
    q: 'How does social media improve my Google rankings?',
    a: 'Social activity reinforces your authority to Google. More importantly, an active Google Business Profile with weekly posts and fresh photos directly impacts your position in local search results. This is one of the most underused levers in local marketing.',
  },
  {
    q: 'Which platforms should I be on?',
    a: 'For residential contractors: Facebook (primary), Instagram (brand building), and Google Business Profile (local search). For commercial work, add LinkedIn. For younger homeowners, add TikTok and Instagram Reels. YouTube is essential if you\'re serious about establishing authority.',
  },
  {
    q: 'Can I review posts before they go live?',
    a: 'Yes. Every plan includes a content approval workflow. You see it first. You approve it. It only posts when you give the green light. You\'ll never be surprised by a post that doesn\'t represent your company correctly.',
  },
];

// Shared theme tokens (matching the Direct Mail Plus page)
const eyebrowPill = 'inline-flex items-center gap-2 rounded-full bg-[#fde8e9] px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-[#c01620]';
const btnPrimary = 'inline-flex items-center justify-center gap-2 rounded-md bg-[#ED1C24] px-7 py-4 text-sm font-extrabold uppercase tracking-wide text-white shadow-lg transition-all hover:bg-[#c8161d] hover:shadow-xl active:translate-y-px';
const btnPrimaryFull = `w-full ${btnPrimary}`;
const btnOutlineDark = 'inline-flex w-full items-center justify-center gap-2 rounded-md px-7 py-4 text-sm font-extrabold uppercase tracking-wide text-[#0f2747] ring-1 ring-ink-200 transition-all hover:text-[#ED1C24] hover:ring-[#ED1C24]';
const cardBase = 'rounded-2xl bg-white ring-1 ring-ink-100 shadow-soft transition-all hover:-translate-y-1 hover:ring-[#ED1C24]/40';

// Client logo marquee (two opposite-direction rows, seamless loop)
const rotate = (arr: typeof CLIENT_LOGOS, n: number) => arr.slice(n).concat(arr.slice(0, n));
const rowA = CLIENT_LOGOS;
const rowB = rotate(CLIENT_LOGOS, Math.floor(CLIENT_LOGOS.length / 2));
---

<BaseLayout
  title="Social Media Marketing for Home Services | PrintFast"
  appendSiteName={false}
  description="Done-for-you social media for home services from a home service marketing agency. Content, engagement, Facebook ads for HVAC and reporting for contractors."
  keywords={[
    'social media marketing for home service companies',
    'home service marketing agency',
    'social media for contractors',
    'trades marketing agency USA',
    'HVAC social media marketing',
    'plumbing social media agency',
    'done-for-you social media for home services',
    'Facebook ads for HVAC',
  ]}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Services', href: '/#services' },
    { name: 'Social Media Marketing', href: '/social-media-marketing/' },
  ]}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Social Media Marketing for Home Service Companies',
    serviceType: 'Done-for-you social media for home services',
    description: 'Social media marketing for home service companies, including content production, publishing, community management, reputation support and paid social campaigns for contractors.',
    provider: { '@type': 'Organization', name: 'PrintFast Digital Marketing' },
    areaServed: { '@type': 'Country', name: 'United States' },
    audience: {
      '@type': 'Audience',
      audienceType: 'HVAC, plumbing, roofing, electrical and home service contractors',
    },
    offers: [
      { '@type': 'Offer', name: 'Foundation Plan', price: '299.00', priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Growth Plan',     price: '399.00', priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Authority Plan',  price: '699.00', priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Enterprise Plan', priceCurrency: 'USD' },
    ],
  }}
>
  <!-- ===================== HERO BANNER ===================== -->
  <section class="relative overflow-hidden bg-[#0f2747]">
    <img
      src="/images/social-media-banner.webp"
      alt="Social media marketing for home service companies — PrintFast"
      class="absolute inset-y-0 right-0 h-full w-full object-cover object-center lg:w-3/5 lg:object-right"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-r from-[#0f2747] from-30% via-[#0f2747]/95 via-55% to-[#0f2747]/30 lg:to-transparent"></div>
    <div aria-hidden="true" class="absolute inset-0 bg-[#0f2747]/40 lg:hidden"></div>

    <div class="container-pf relative py-16 sm:py-20 lg:py-28">
      <div class="max-w-xl lg:max-w-2xl">
        <p class="inline-flex rounded-md bg-[#ED1C24] px-3 py-1.5 text-xs font-extrabold uppercase tracking-[0.18em] text-white">
          Social Media Marketing
        </p>

        <h1 class="mt-5 font-display text-4xl font-extrabold uppercase leading-[1.03] tracking-tight text-white sm:text-5xl lg:text-6xl">
          Social Media Marketing for Home Service Companies That <span class="text-[#ED1C24]">Books Real Jobs</span>
        </h1>

        <p class="mt-6 max-w-xl text-sm leading-relaxed text-white/80 sm:text-base">
          PrintFast is a dedicated home service marketing agency with a team that plans, produces, and publishes content built for contractors. Whether you run an HVAC company, plumbing business, electrical service, or roofing crew — we manage your entire social media presence so your phone keeps ringing. Less guesswork. More booked service calls. A brand your local customers trust.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href={getContactHref('managed-social-media')} class={btnPrimary}>
            Get My Social Media Proposal <i class="fa-solid fa-arrow-right text-xs"></i>
          </a>
          <a href="#pricing" class="inline-flex items-center justify-center gap-2 rounded-md px-7 py-4 text-sm font-extrabold uppercase tracking-wide text-white ring-1 ring-white/40 transition-all hover:bg-white/10">
            See pricing
          </a>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3">
          {trustItems.map((item) => (
            <span class="inline-flex items-center gap-2 text-sm font-medium text-white/80">
              <i class="fa-solid fa-circle-check text-[#ED1C24]"></i> {item}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== STATS ===================== -->
  <section class="section-tight">
    <div class="container-pf">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {proofPoints.map((p) => (
          <div class="rounded-2xl bg-white p-7 text-center ring-1 ring-ink-100 shadow-soft" data-reveal>
            <p class="font-display text-4xl font-extrabold text-[#ED1C24]">{p.stat}</p>
            <p class="mt-2 text-sm text-ink-600">{p.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== PLATFORMS ===================== -->
  <section class="section-tight">
    <div class="container-pf">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <p class={eyebrowPill}><i class="fa-solid fa-bolt"></i> Where we'll show up</p>
        <h2 class="heading-lg mt-4 text-[#0f2747]">We Manage Every Platform Where Home Service Customers Actually Spend Time</h2>
      </div>
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {platforms.map((p) => (
          <div class="flex items-center gap-4 rounded-2xl bg-white p-5 ring-1 ring-ink-100 shadow-soft transition-all hover:-translate-y-1 hover:ring-[#ED1C24]/40" data-reveal>
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl text-xl" style={`background-color: ${p.bg}; color: ${p.color}`}>
              <i class:list={['fa-brands', p.icon]}></i>
            </span>
            <div class="min-w-0">
              <p class="font-semibold text-[#0f2747]">{p.name}</p>
              <p class="mt-0.5 text-xs text-ink-500">{p.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== WHY NOT A GENERIC AGENCY ===================== -->
  <section class="section">
    <div class="container-pf">
      <div class="grid items-center gap-12 lg:grid-cols-[1fr_550px]">
        <div data-reveal>
          <p class={eyebrowPill}><i class="fa-solid fa-bolt"></i> Why not just hire a generic agency?</p>
          <h2 class="heading-lg mt-4 text-[#0f2747]">Why Not Just Hire a Generic Social Media Agency?</h2>
          <p class="lead mt-5">
            Because a generic agency doesn't know the trades. They don't understand why plumbers get slammed in January and slow in July. They don't know that HVAC season is different in Minnesota than in Florida. They don't understand that homeowners in Atlanta respond differently to messaging than homeowners in rural Texas. They post pretty pictures and chase vanity metrics like follows and likes. But follows don't pay your technicians. Likes don't schedule service calls. Calls do.
          </p>
          <p class="lead mt-5">
            PrintFast has spent 35 years in trades marketing. We know the language. We know the seasonal swings. We know what moves customers in your market because we've been doing this since before Facebook existed. When you hire PrintFast, you're not getting a generalist with a Canva account. You're getting a team that already won in your industry.
          </p>
        </div>
        <div class="overflow-hidden rounded-[2rem] bg-ink-50 p-4 shadow-soft ring-1 ring-ink-100" data-reveal>
          <img
            src="/images/pf-expertise.webp"
            alt="PrintFast trades marketing expertise — 35 years serving home service companies"
            width="1200"
            height="849"
            class="h-auto w-full rounded-[1.5rem]"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== WHAT YOU GET ===================== -->
  <section class="section bg-ink-50/60">
    <div class="container-pf">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <p class={eyebrowPill}><i class="fa-solid fa-bolt"></i> What's included</p>
        <h2 class="heading-lg mt-4 text-[#0f2747]">A full social team — without the overhead</h2>
        <p class="lead mt-5">Strategy, production, publishing, paid and reputation for social media marketing for home service companies. One contract, one accountable team, one dashboard.</p>
      </div>
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {whatYouGet.map((item) => (
          <div class:list={['flex flex-col p-6', cardBase]} data-reveal>
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-[#fde8e9] text-xl text-[#ED1C24]">
              <i class:list={['fa-solid', item.icon]}></i>
            </span>
            <h3 class="mt-5 text-lg font-extrabold text-[#0f2747]">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-600">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== PRICING ===================== -->
  <section id="pricing" class="section bg-ink-50/60">
    <div class="container-pf">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <p class={eyebrowPill}><i class="fa-solid fa-bolt"></i> Plans & pricing</p>
        <h2 class="heading-lg mt-4 text-[#0f2747]">Transparent monthly pricing — no hidden fees</h2>
        <p class="lead mt-5">PFA social growth plans are month-to-month and billed in USD. Annual plans waive the one-time setup fee.</p>
      </div>
      <div class="mt-12 grid gap-6 lg:grid-cols-2 xl:grid-cols-4">
        {plans.map((p) => (
          <article
            class:list={[
              'relative flex flex-col rounded-2xl bg-white p-7 transition-all sm:p-8',
              p.popular
                ? 'ring-2 ring-[#ED1C24] shadow-xl lg:-translate-y-2'
                : 'ring-1 ring-ink-100 shadow-soft hover:-translate-y-1 hover:ring-[#ED1C24]/40',
            ]}
            data-reveal
          >
            {p.popular && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-[#ED1C24] px-4 py-1 text-[0.7rem] font-extrabold uppercase tracking-wider text-white shadow-lg">Popular</span>
            )}

            <header>
              <h3 class="font-display text-lg font-extrabold text-[#0f2747]">{p.name}</h3>
              {p.description && <p class="mt-2 text-sm text-ink-500">{p.description}</p>}
            </header>

            <div class="mt-6 flex items-baseline gap-1">
              <span class="font-display text-4xl font-extrabold text-[#0f2747]">{p.price}</span>
              <span class="text-sm text-ink-500">{p.period ?? '/mo'}</span>
            </div>

            <ul class="mt-6 flex-1 space-y-3">
              {p.features.map((f) => (
                <li class="flex items-start gap-3 text-sm text-ink-700">
                  <i class="fa-solid fa-circle-check mt-0.5 text-[#ED1C24]"></i>
                  <span>{f}</span>
                </li>
              ))}
            </ul>

            <a href={p.cta.href} class:list={['mt-8', p.popular ? btnPrimaryFull : btnOutlineDark]}>
              {p.cta.label} <i class="fa-solid fa-arrow-right text-xs"></i>
            </a>
          </article>
        ))}
      </div>
      <div class="mx-auto mt-8 flex max-w-2xl flex-col items-center gap-3 text-center text-sm text-ink-500">
        <p>
          All plans include: PrintFast.social platform access, Canva integration, syndicated image/GIF library, month-ahead content planning, brand templates, local market alignment, keyword research, and audience growth setup. Additional team logins available at $10/month each.
        </p>
      </div>
    </div>
  </section>

  <!-- ===================== PROCESS ===================== -->
  <section class="section">
    <div class="container-pf">
      <div class="grid items-start gap-10 lg:grid-cols-12">
        <div class="lg:col-span-5" data-reveal>
          <p class={eyebrowPill}><i class="fa-solid fa-bolt"></i> How we work</p>
          <h2 class="heading-lg mt-4 text-[#0f2747]">Your Home Service Social Media Program — Live in 14 Days</h2>
          <p class="lead mt-5">
            We replace the chaos of agency hand-offs with one team, one plan and clear weekly progress — designed for contractors and home service brands.
          </p>
          <a href={getContactHref('managed-social-media')} class:list={['mt-8', btnPrimary]}>
            Talk to a strategist <i class="fa-solid fa-arrow-right text-xs"></i>
          </a>
        </div>
        <ol class="grid gap-5 sm:grid-cols-2 lg:col-span-7">
          {process.map((p) => (
            <li class:list={['p-6', cardBase]} data-reveal>
              <div class="flex items-center justify-between">
                <span class="grid h-12 w-12 place-items-center rounded-full bg-[#ED1C24] text-lg text-white shadow-lg">
                  <i class:list={['fa-solid', p.icon]}></i>
                </span>
                <span class="font-display text-sm font-extrabold tracking-[0.16em] text-[#ED1C24]">{p.n}</span>
              </div>
              <h3 class="mt-4 text-lg font-extrabold uppercase text-[#0f2747]">{p.title}</h3>
              <p class="mt-2 text-sm text-ink-600">{p.desc}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- ===================== FAQ ===================== -->
  <section class="section">
    <div class="container-pf max-w-4xl">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <p class={eyebrowPill}><i class="fa-solid fa-circle-question"></i> FAQs</p>
        <h2 class="heading-lg mt-4 text-[#0f2747]">Questions Home Service Contractors Ask</h2>
      </div>
      <div class="mt-10 space-y-4">
        {faqs.map((f) => (
          <details class="group rounded-2xl bg-white p-6 ring-1 ring-ink-100 shadow-soft transition-colors hover:ring-[#ED1C24]/40" data-reveal>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
              <span class="font-bold text-[#0f2747]">{f.q}</span>
              <i class="fa-solid fa-plus text-[#ED1C24] transition-transform group-open:rotate-45"></i>
            </summary>
            <p class="mt-4 text-sm leading-relaxed text-ink-600">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== TESTIMONIALS ===================== -->
  <section class="section bg-ink-50/60">
    <div class="container-pf">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <p class={eyebrowPill}><i class="fa-solid fa-bolt"></i> Trust signals</p>
        <h2 class="heading-lg mt-4 text-[#0f2747]">What Home Service Business Owners Say About PrintFast</h2>
        <p class="lead mt-5">Real stories from contractors using PrintFast as their home service marketing agency.</p>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {TESTIMONIALS.map((t) => (
          <figure class="flex flex-col gap-5 rounded-2xl bg-white p-7 ring-1 ring-ink-100 shadow-soft sm:p-8" data-reveal>
            <div class="flex items-center gap-1 text-[#ED1C24]">
              {Array.from({ length: t.rating }).map(() => (
                <i class="fa-solid fa-star text-sm"></i>
              ))}
            </div>
            <blockquote class="leading-relaxed text-ink-800">
              <i class="fa-solid fa-quote-left mr-2 text-[#ED1C24]/30"></i>
              {t.quote}
            </blockquote>
            <figcaption class="mt-auto flex items-center gap-3 border-t border-ink-100 pt-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-[#fde8e9] font-bold text-[#ED1C24]">
                {t.name.charAt(0)}
              </span>
              <span>
                <span class="block text-sm font-semibold text-[#0f2747]">{t.name}</span>
                <span class="block text-xs text-ink-500">{t.role}</span>
              </span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== CLIENT LOGOS ===================== -->
  <section class="section border-y border-ink-100 bg-ink-50/60" aria-label="Our clients">
    <div class="container-pf">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <p class={eyebrowPill}><i class="fa-solid fa-bolt"></i> Trusted partners</p>
        <h2 class="heading-lg mt-4 text-[#0f2747]">In good company</h2>
        <p class="lead mt-5">Hundreds of U.S. home service brands trust PrintFast to run their social.</p>
      </div>

      <div class="mt-10 space-y-6">
        <div class="pf-marquee pf-marquee--logos">
          <div class="pf-marquee__track">
            {[...rowA, ...rowA].map((logo, i) => (
              <div class="pf-logo-cell" aria-hidden={i >= rowA.length ? 'true' : 'false'}>
                <img src={logo.src} alt={logo.name} loading="lazy" decoding="async" width="180" height="80" class="pf-logo-img" />
              </div>
            ))}
          </div>
        </div>

        <div class="pf-marquee pf-marquee--logos">
          <div class="pf-marquee__track pf-marquee__track--reverse">
            {[...rowB, ...rowB].map((logo, i) => (
              <div class="pf-logo-cell" aria-hidden={i >= rowB.length ? 'true' : 'false'}>
                <img src={logo.src} alt={logo.name} loading="lazy" decoding="async" width="180" height="80" class="pf-logo-img" />
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FINAL CTA ===================== -->
  <section class="section">
    <div class="container-pf">
      <div class="relative overflow-hidden rounded-3xl bg-[#0f2747] px-6 py-14 sm:p-14 lg:p-20" data-reveal>
        <span aria-hidden="true" class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-white/5 blur-3xl"></span>
        <span aria-hidden="true" class="absolute -bottom-24 -left-24 h-72 w-72 rounded-full bg-[#ED1C24]/30 blur-3xl"></span>

        <div class="relative max-w-3xl">
          <p class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-white ring-1 ring-white/20">
            <i class="fa-solid fa-bolt"></i> Ready to grow your local brand?
          </p>
          <h2 class="heading-lg mt-5 text-white">
            Work With a Home Service Marketing Agency That <span class="text-[#ED1C24]">Knows the Trades.</span>
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-white/85">
            Tell us about your HVAC, plumbing, electrical or roofing company and we'll send a done-for-you social media plan within one business day.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={getContactHref('managed-social-media')} class={btnPrimary}>
              Get My Social Media Proposal <i class="fa-solid fa-arrow-right text-xs"></i>
            </a>
            <a href="#contact" class="inline-flex items-center justify-center gap-2 rounded-md px-7 py-4 text-sm font-extrabold uppercase tracking-wide text-white ring-1 ring-white/40 transition-all hover:bg-white/10">
              Talk to a strategist
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="contact" class="section">
    <div class="container-pf max-w-4xl">
      <ContactForm
        title="Talk to our social team"
        subtitle="Send us a few details — we'll reply with a custom plan within one business day."
      />
    </div>
  </section>

  <section class="section-tight pt-0">
    <div class="container-pf">
      <div class="rounded-2xl bg-[#0f2747] p-6 text-sm leading-relaxed text-white/80 ring-1 ring-white/10 shadow-soft sm:p-8" data-reveal>
        <p>
          <strong class="text-white">All plans include:</strong> PrintFast.social platform access, Canva integration, syndicated image/GIF library, month-ahead content planning, brand templates, local market alignment, keyword research, and audience growth setup. Additional team logins available at $10/month each.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
