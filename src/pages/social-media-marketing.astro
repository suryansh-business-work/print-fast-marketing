---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import SectionHeading from '@components/SectionHeading.astro';
import FeatureGrid from '@components/FeatureGrid.astro';
import PricingCard from '@components/PricingCard.astro';
import Testimonials from '@components/Testimonials.astro';
import CTA from '@components/CTA.astro';
import ContactForm from '@components/ContactForm.astro';
import ClientLogos from '@components/ClientLogos.astro';

const platforms = [
  { name: 'Facebook',  icon: 'fa-facebook',  note: '#1 home service lead-gen channel for adults 35+' },
  { name: 'Instagram', icon: 'fa-instagram', note: 'Reels & Stories for local homeowners' },
  { name: 'TikTok',    icon: 'fa-tiktok',    note: 'Fastest-growing local discovery channel' },
  { name: 'YouTube',   icon: 'fa-youtube',   note: 'Long-form trust + Shorts reach' },
  { name: 'LinkedIn',  icon: 'fa-linkedin',  note: 'B2B, commercial & recruiting' },
  { name: 'Pinterest', icon: 'fa-pinterest', note: 'High-intent home & lifestyle search' },
  { name: 'X / Twitter', icon: 'fa-x-twitter', note: 'Real-time customer service' },
  { name: 'Google Business', icon: 'fa-google', note: 'Posts that support local contractor rankings' },
];

const whatYouGet = [
  { icon: 'fa-pen-fancy',           title: 'Channel-native content',  description: 'Social media for contractors built platform by platform: Reels, carousels, Shorts, Stories and posts that feel native instead of copy-pasted.' },
  { icon: 'fa-calendar-days',       title: 'Editorial calendar',       description: 'A 30-, 60- and 90-day plan tied to HVAC social media marketing seasons, plumbing offers, storm response, U.S. holidays and local service demand.' },
  { icon: 'fa-comments',            title: 'Community management',     description: 'We answer DMs, comments and reviews in your voice — helping homeowners feel heard before they call your crew.' },
  { icon: 'fa-bullhorn',            title: 'Paid social campaigns',    description: 'Facebook ads for HVAC, Meta retargeting, TikTok and YouTube campaigns with audience-by-zip targeting, lookalikes and service-area exclusions.' },
  { icon: 'fa-camera-retro',        title: 'On-site shoots (optional)', description: 'Quarterly content days where we capture technician stories, before-and-after work, fleet shots and seasonal service assets in one visit.' },
  { icon: 'fa-user-shield',         title: 'Reputation & reviews',     description: 'Active monitoring across Google, Facebook, Yelp and Nextdoor for HVAC, plumbing, roofing and electrical teams — with response templates and escalation.' },
  { icon: 'fa-people-group',        title: 'Employee advocacy',        description: 'Turn your crew into creators with simple capture kits, approval workflows and prompts built for busy home service technicians.' },
  { icon: 'fa-chart-pie',           title: 'Monthly reporting',        description: 'A home service marketing agency dashboard plus a one-page exec summary: reach, engagement, calls, leads and return on paid social spend.' },
];

const proofPoints = [
  { stat: '78%', label: 'of homeowners research home service providers on social media before calling (Source: BrightLocal Local Consumer Review Survey)' },
  { stat: '63%', label: 'of HVAC and plumbing leads check Facebook or Instagram reviews before calling a contractor (Source: LSA Insider Report)' },
  { stat: '3.4×', label: 'higher conversion rate when paid social is paired with organic for home service businesses (Source: Podium State of Online Reviews)' },
  { stat: '#1', label: 'platform for home service lead generation: Facebook for U.S. adults 35+ (Source: Meta for Business Home Services Vertical Insights)' },
];

const process = [
  { n: '01', title: 'Audit & strategy',  desc: 'We audit your current social presence, analyze local competitors in your trade, define your content pillars (trust, proof, offers, community), and build a measurable 90-day social media plan for your home service business.', icon: 'fa-compass' },
  { n: '02', title: 'Production',        desc: 'We produce trade-specific captions, branded graphics, short-form service videos, and seasonal promotional content — all reviewed and approved by you before publishing.', icon: 'fa-clapperboard' },
  { n: '03', title: 'Publish & engage',  desc: 'We schedule, publish, and reply to your customers across every platform while you stay focused on running service calls and managing your crew.', icon: 'fa-paper-plane' },
  { n: '04', title: 'Optimize & scale',  desc: "We run weekly tests on ad hooks, content formats, and audience targeting to find what drives calls in your service area. What works gets scaled; what doesn't gets cut — fast.", icon: 'fa-arrows-spin' },
];

const plans = [
  {
    name: 'Essentials',
    price: '$99',
    description: 'Get started with consistent multi-platform posting.',
    features: [
      'Access to PrintFast.Social',
      '24 custom posts / month on up to 4 platforms',
      '12 social media accounts (per brand)',
      '5 user licenses',
      'Bulk scheduling & CSV uploads',
      'Calendar view & post preview',
      'URL shortener & UTM parameters',
    ],
    cta: { label: 'Start with Essentials', href: '/contact-us/' },
  },
  {
    name: 'Basic',
    price: '$345',
    description: 'Richer creative formats with deeper reporting.',
    features: [
      'Access to PrintFast.Social',
      '8 custom posts / month on up to 4 platforms',
      '3 social media accounts (per brand)',
      '1 user license',
      'GIF, video, multi-image & carousel posts',
      'Custom call-to-actions',
      'Detailed analytics + PDF reports (emailed)',
      'Zapier integration',
    ],
    cta: { label: 'Choose Basic', href: '/contact-us/' },
  },
  {
    name: 'Premium',
    price: '$495',
    description: 'Our most popular plan — full workflow, approvals & integrations.',
    popular: true,
    features: [
      'Access to PrintFast.Social',
      '12 custom posts / month on up to 4 platforms',
      'Advanced keyword & hashtag analysis',
      '5 social media accounts (per brand) · 2 user licenses',
      'RSS-feed scheduling, smart queues & location tagging',
      'Content approval workflows',
      'Slack, Canva, Google Drive, Dropbox & Box integrations',
      'Mobile app + scheduled PDF reports',
    ],
    cta: { label: 'Choose Premium', href: '/contact-us/' },
  },
];

const faqs = [
  { q: 'Do I keep ownership of my content and ad accounts?',
    a: 'Always. Every account, asset and creative we produce for your done-for-you social media for home services program is owned by you and lives in your business accounts — not ours.' },
  { q: 'How long until I see results?',
    a: 'Engagement and reach typically lift within 30–45 days. HVAC social media marketing, plumbing social media agency programs and lead-driving paid campaigns usually show qualified results inside the first 60 days.' },
  { q: 'Do you run Facebook ads for HVAC and plumbing companies?',
    a: 'Yes. We build Facebook ads for HVAC, plumbing, electrical, roofing and other home service brands with service-area targeting, call-focused creative, retargeting audiences and performance reporting.' },
  { q: 'Will you respond to my reviews and DMs?',
    a: 'Yes. On Growth and Scale plans we monitor and respond on your behalf within two business hours during U.S. business hours, with escalation rules you set.' },
  { q: 'Are contracts month-to-month?',
    a: 'Yes. We earn the relationship every month. There are no long-term commitments or cancellation fees for contractors who need flexible social media support.' },
  { q: 'Do you handle TCPA, FTC and platform compliance?',
    a: 'Yes — including endorsement and testimonial disclosures (FTC), platform-specific ad policies, and proper opt-in language for any SMS or paid social promotions.' },
];
---

<BaseLayout
  title="Social Media Marketing for Home Services | PrintFast"
  appendSiteName={false}
  description="Done-for-you social media for home services from a home service marketing agency. Content, engagement, Facebook ads for HVAC and reporting for contractors."
  keywords={[
    'social media marketing for home service companies',
    'home service marketing agency',
    'social media for contractors',
    'trades marketing agency USA',
    'HVAC social media marketing',
    'plumbing social media agency',
    'done-for-you social media for home services',
    'Facebook ads for HVAC',
  ]}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Services', href: '/#services' },
    { name: 'Social Media Marketing', href: '/social-media-marketing/' },
  ]}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Social Media Marketing for Home Service Companies',
    serviceType: 'Done-for-you social media for home services',
    description: 'Social media marketing for home service companies, including content production, publishing, community management, reputation support and paid social campaigns for contractors.',
    provider: { '@type': 'Organization', name: 'PrintFast Digital Marketing' },
    areaServed: { '@type': 'Country', name: 'United States' },
    audience: {
      '@type': 'Audience',
      audienceType: 'HVAC, plumbing, roofing, electrical and home service contractors',
    },
    offers: [
      { '@type': 'Offer', name: 'Essentials', price: '99',  priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Basic',      price: '345', priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Premium',    price: '495', priceCurrency: 'USD' },
    ],
  }}
>
  <Hero
    variant="service"
    eyebrow="Social Media Marketing"
    title="Social Media Marketing for Home Service Companies That"
    highlight="Books Real Jobs"
    description="PrintFast is a dedicated home service marketing agency with a team that plans, produces, and publishes content built for contractors. Whether you run an HVAC company, plumbing business, electrical service, or roofing crew — we manage your entire social media presence so your phone keeps ringing. Less guesswork. More booked service calls. A brand your local customers trust."
    primaryCta={{ label: 'Get My Social Media Proposal', href: '/contact-us/' }}
    secondaryCta={{ label: 'See pricing', href: '#pricing' }}
    trustItems={['Built for HVAC, Plumbing & Home Services', 'Done-for-you social media', 'Free strategy call']}
  />

  <!-- Stats -->
  <section class="section-tight">
    <div class="container-pf">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {proofPoints.map((p) => (
          <div class="card p-7 text-center" data-reveal>
            <p class="font-display text-4xl font-extrabold gradient-text">{p.stat}</p>
            <p class="mt-2 text-sm text-ink-600">{p.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Platforms -->
  <section class="section-tight">
    <div class="container-pf">
      <SectionHeading eyebrow="Where we'll show up" title="Every channel your U.S. customers use" />
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {platforms.map((p) => (
          <div class="card p-5 flex items-center gap-4" data-reveal>
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600 text-xl">
              <i class:list={[p.icon.startsWith('fa-google') ? 'fa-brands' : 'fa-brands', p.icon]}></i>
            </span>
            <div class="min-w-0">
              <p class="font-semibold text-ink-900">{p.name}</p>
              <p class="text-xs text-ink-500 mt-0.5">{p.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What you get -->
  <section class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="What's included"
        title="A full social team — without the overhead"
        description="Strategy, production, publishing, paid and reputation for social media marketing for home service companies. One contract, one accountable team, one dashboard."
      />
      <div class="mt-14">
        <FeatureGrid items={whatYouGet} columns={4} />
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Plans & pricing"
        title="Transparent monthly pricing — no hidden fees"
        description="All plans are month-to-month and billed in USD. Need a custom build for multi-location or franchise? We'll design it around you."
      />
      <div class="mt-14 grid gap-6 lg:grid-cols-3">
        {plans.map((p) => <PricingCard {...p} />)}
      </div>
      <p class="mt-8 text-center text-sm text-ink-500">
        Paid social ad spend is billed directly by the platform to your card.
        <span class="font-semibold text-brand-700"> Save 10% on annual prepay.</span>
      </p>
    </div>
  </section>

  <!-- Process -->
  <section class="section">
    <div class="container-pf">
      <div class="grid lg:grid-cols-12 gap-10 items-start">
        <div class="lg:col-span-5">
          <p class="eyebrow"><i class="fa-solid fa-bolt text-brand-600"></i> How we work</p>
          <h2 class="heading-lg mt-4">Your Home Service Social Media Program — Live in 14 Days</h2>
          <p class="lead mt-5">
            We replace the chaos of agency hand-offs with one team, one plan and clear weekly progress — designed for U.S. contractors and home service brands.
          </p>
          <a href="/contact-us/" class="btn-primary mt-8">Talk to a strategist</a>
        </div>
        <ol class="lg:col-span-7 grid sm:grid-cols-2 gap-5">
          {process.map((p) => (
            <li class="card p-6" data-reveal>
              <div class="flex items-center justify-between">
                <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600">
                  <i class:list={['fa-solid', p.icon]}></i>
                </span>
                <span class="text-xs font-mono text-ink-400">{p.n}</span>
              </div>
              <h3 class="mt-4 text-lg font-bold text-ink-900">{p.title}</h3>
              <p class="mt-2 text-sm text-ink-600">{p.desc}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section">
    <div class="container-pf max-w-4xl">
      <SectionHeading eyebrow="FAQs" title="Common questions" />
      <div class="mt-10 space-y-3">
        {faqs.map((f) => (
          <details class="group card p-6 transition-colors hover:ring-brand-200">
            <summary class="flex cursor-pointer items-center justify-between gap-4 list-none">
              <span class="font-semibold text-ink-900">{f.q}</span>
              <i class="fa-solid fa-plus text-ink-400 group-open:rotate-45 transition-transform"></i>
            </summary>
            <p class="mt-4 text-ink-600 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Testimonials
    title="What Home Service Business Owners Say About PrintFast"
    description="Real stories from contractors using PrintFast as their home service marketing agency."
  />

  <ClientLogos
    eyebrow="Trusted partners"
    title="In good company"
    description="Hundreds of U.S. home service brands trust PrintFast to run their social."
    background="muted"
  />

  <CTA
    eyebrow="Ready to grow your local brand?"
    title="Work With a Home Service Marketing Agency That Knows the Trades."
    description="Tell us about your HVAC, plumbing, electrical or roofing company and we'll send a done-for-you social media plan within one business day."
    primaryCta={{ label: 'Get My Social Media Proposal', href: '/contact-us/' }}
    secondaryCta={{ label: 'Talk to a strategist', href: '#contact' }}
  />

  <section id="contact" class="section">
    <div class="container-pf max-w-4xl">
      <ContactForm
        title="Talk to our social team"
        subtitle="Send us a few details — we'll reply with a custom plan within one business day."
      />
    </div>
  </section>
</BaseLayout>
