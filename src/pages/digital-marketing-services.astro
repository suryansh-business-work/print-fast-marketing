---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeading from '@components/SectionHeading.astro';
import CTA from '@components/CTA.astro';
import Stats from '@components/Stats.astro';
import Testimonials from '@components/Testimonials.astro';
import Lottie from '@components/Lottie.astro';
import { SERVICES } from '@data/site';

const channels = [
  { icon: 'fa-magnifying-glass-chart', title: 'Search (SEO + SEM)', desc: 'Rank for the work that pays — local maps, organic and paid search.' },
  { icon: 'fa-share-nodes', title: 'Social Media', desc: 'Multi-network publishing, content production, community & analytics.' },
  { icon: 'fa-video', title: 'Video Production', desc: 'Story-led videos for site, social, ads, sales and email.' },
  { icon: 'fa-bullhorn', title: 'Paid Ads', desc: 'Google, Meta and YouTube campaigns built around real lead value.' },
  { icon: 'fa-envelope-open-text', title: 'Email & SMS', desc: 'Lifecycle automations that recover quotes and nurture customers.' },
  { icon: 'fa-globe', title: 'Web & Landing Pages', desc: 'Fast, accessible, SEO-grade pages tuned to convert.' },
  { icon: 'fa-star', title: 'Reputation', desc: 'Review acquisition + monitoring to dominate local trust signals.' },
  { icon: 'fa-chart-line', title: 'Analytics & Reporting', desc: 'Single dashboard tying calls, forms and revenue to channels.' },
];

const process = [
  { n: '01', title: 'Discover', desc: 'Free Digital Review — audit, competitor scan and goal alignment.', icon: 'fa-compass' },
  { n: '02', title: 'Plan',     desc: 'A 90-day roadmap mapped to the channels that move your needle.',    icon: 'fa-pen-ruler' },
  { n: '03', title: 'Launch',   desc: 'Production, publishing and paid setup — fast, with QA at every step.', icon: 'fa-rocket' },
  { n: '04', title: 'Optimize', desc: 'Weekly reviews, monthly reporting, quarterly roadmap refresh.',     icon: 'fa-arrows-spin' },
];

const industries = [
  { name: 'HVAC',        icon: 'fa-snowflake' },
  { name: 'Plumbing',    icon: 'fa-faucet-drip' },
  { name: 'Electrical',  icon: 'fa-bolt' },
  { name: 'Roofing',     icon: 'fa-house-chimney' },
  { name: 'Landscaping', icon: 'fa-tree' },
  { name: 'Cleaning',    icon: 'fa-broom' },
  { name: 'Pest Control',icon: 'fa-bug-slash' },
  { name: 'Pool & Spa',  icon: 'fa-water-ladder' },
];
---

<BaseLayout
  title="Digital Marketing Services"
  description="A full-stack digital marketing partner for HVAC, plumbing, electrical and home-service brands — SEO, social, video, paid, email and reputation under one roof."
  keywords={[
    'digital marketing services',
    'home service marketing agency',
    'HVAC digital marketing',
    'plumbing marketing services',
    'electrical contractor marketing',
    'all-in-one marketing agency',
    'lead generation for trades',
  ]}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Digital Marketing Services', href: '/digital-marketing-services/' },
  ]}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: 'Full-Service Digital Marketing',
    provider: { '@type': 'Organization', name: 'Print Fast Digital Marketing' },
    areaServed: 'United States',
  }}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-hero-radial">
    <div class="absolute inset-0 -z-10 bg-grid-light bg-grid-32 opacity-40 [mask-image:radial-gradient(ellipse_at_center,#000_60%,transparent_100%)]" aria-hidden="true"></div>
    <div class="container-pf grid lg:grid-cols-12 gap-10 lg:gap-14 items-center py-16 sm:py-20 lg:py-28">
      <div class="lg:col-span-7 min-w-0" data-reveal>
        <p class="eyebrow"><i class="fa-solid fa-bolt text-brand-600"></i> Digital Marketing Services</p>
        <h1 class="heading-xl mt-4">
          One <span class="gradient-text">growth team</span> for every channel that drives jobs.
        </h1>
        <p class="lead mt-5 max-w-2xl">
          Search, social, video, paid ads, email and reputation — built for HVAC, plumbing, electrical and home-service brands. Fewer vendors, faster results, one accountable team.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/free-digital-review/" class="btn-primary">Get my free review <i class="fa-solid fa-arrow-right text-xs"></i></a>
          <a href="/contact-us/" class="btn-outline">Talk to a strategist</a>
        </div>
        <ul class="mt-8 flex flex-wrap gap-4 text-sm text-ink-600">
          <li class="inline-flex items-center gap-2"><i class="fa-solid fa-circle-check text-brand-600"></i> 15+ years in the trades</li>
          <li class="inline-flex items-center gap-2"><i class="fa-solid fa-circle-check text-brand-600"></i> 500+ home-service brands</li>
          <li class="inline-flex items-center gap-2"><i class="fa-solid fa-circle-check text-brand-600"></i> No long-term contracts</li>
        </ul>
      </div>
      <div class="lg:col-span-5 min-w-0" data-reveal>
        <div class="relative aspect-square max-w-md mx-auto">
          <div aria-hidden="true" class="absolute inset-0 rounded-[2rem] bg-gradient-to-br from-brand-500/15 to-accent-400/20 blur-2xl"></div>
          <div class="relative h-full w-full rounded-[2rem] bg-white ring-1 ring-ink-100 shadow-soft overflow-hidden">
            <Lottie
              src="https://assets10.lottiefiles.com/packages/lf20_w51pcehl.json"
              ariaLabel="Digital marketing growth animation"
              class="h-full w-full"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Channels grid -->
  <section class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="What we do"
        title="Every channel that drives the phone to ring"
        description="Mix and match — or run the full stack. We design the system around your goals, market and capacity."
      />
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {channels.map((c) => (
          <div class="card-hover p-6" data-reveal>
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600 text-lg">
              <i class:list={['fa-solid', c.icon]} aria-hidden="true"></i>
            </span>
            <h3 class="mt-5 text-lg font-bold text-ink-900">{c.title}</h3>
            <p class="mt-2 text-sm text-ink-600 leading-relaxed">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured services with image -->
  <section class="section bg-ink-50/40">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Core services"
        title="Headline solutions, ready to deploy"
        description="Each plays well alone — and even better together."
      />
      <div class="mt-12 grid gap-6 lg:grid-cols-2">
        {SERVICES.map((s, i) => (
          <a href={s.href} class="card-hover p-6 sm:p-8 group flex gap-5" data-reveal>
            <span class="grid h-14 w-14 flex-shrink-0 place-items-center rounded-2xl bg-gradient-to-br from-brand-500 to-brand-700 text-white text-xl shadow-soft">
              <i class:list={['fa-solid', s.icon]} aria-hidden="true"></i>
            </span>
            <div class="min-w-0">
              <h3 class="text-xl font-bold text-ink-900 group-hover:text-brand-700 transition-colors">{s.title}</h3>
              <p class="mt-2 text-ink-600 leading-relaxed">{s.description}</p>
              <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-brand-700">
                Explore <i class="fa-solid fa-arrow-right text-xs transition-transform group-hover:translate-x-1"></i>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section">
    <div class="container-pf">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-5 min-w-0" data-reveal>
          <p class="eyebrow"><i class="fa-solid fa-bolt text-brand-600"></i> How we work</p>
          <h2 class="heading-lg mt-4">A predictable engagement, end to end.</h2>
          <p class="lead mt-5">
            We replace the chaos of agency hand-offs with one team, one plan, one dashboard — and clear weekly progress.
          </p>
          <div class="mt-6">
            <img
              src="https://images.unsplash.com/photo-1551434678-e076c223a692?auto=format&fit=crop&w=900&q=80"
              alt="Marketing team collaborating around a strategy board"
              loading="lazy"
              decoding="async"
              width="900"
              height="600"
              class="w-full rounded-2xl ring-1 ring-ink-100 shadow-soft"
            />
          </div>
        </div>
        <ol class="lg:col-span-7 grid sm:grid-cols-2 gap-5 min-w-0">
          {process.map((p) => (
            <li class="card p-6" data-reveal>
              <div class="flex items-center justify-between">
                <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600">
                  <i class:list={['fa-solid', p.icon]} aria-hidden="true"></i>
                </span>
                <span class="text-xs font-mono text-ink-400">{p.n}</span>
              </div>
              <h3 class="mt-4 text-lg font-bold text-ink-900">{p.title}</h3>
              <p class="mt-2 text-sm text-ink-600">{p.desc}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="section bg-gradient-to-b from-white to-brand-50/40">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Industries"
        title="Built for the home-service trades"
        description="We speak your customers' language — and your operations."
      />
      <ul class="mt-12 grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-3">
        {industries.map((i) => (
          <li class="flex flex-col items-center justify-center gap-3 rounded-2xl bg-white p-5 ring-1 ring-ink-100 hover:ring-brand-300 hover:-translate-y-0.5 transition-all">
            <span class="grid h-12 w-12 place-items-center rounded-full bg-brand-50 text-brand-600 text-lg">
              <i class:list={['fa-solid', i.icon]} aria-hidden="true"></i>
            </span>
            <span class="text-sm font-semibold text-ink-800 text-center">{i.name}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <Stats />

  <Testimonials />

  <section class="section">
    <div class="container-pf">
      <CTA
        eyebrow="Ready to grow?"
        title="Get a free Digital Review tailored to your trade."
        description="A no-cost audit of your SEO, content, local presence and competitors — plus a 1:1 strategy call. No obligation."
        primaryCta={{ label: 'Claim my free review', href: '/free-digital-review/' }}
        secondaryCta={{ label: 'Contact us', href: '/contact-us/' }}
      />
    </div>
  </section>
</BaseLayout>
