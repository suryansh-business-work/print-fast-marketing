---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import SectionHeading from '@components/SectionHeading.astro';
import FeatureGrid from '@components/FeatureGrid.astro';
import Testimonials from '@components/Testimonials.astro';
import CTA from '@components/CTA.astro';
import ContactForm from '@components/ContactForm.astro';
import ClientLogos from '@components/ClientLogos.astro';
import { SITE } from '@data/site';

const pillars = [
  { icon: 'fa-location-dot',         title: 'Local SEO',             description: 'Google Business Profile optimization, NAP consistency, citations, geo-grid rank tracking and review velocity — built for HVAC, plumbing and home service area businesses across the U.S.' },
  { icon: 'fa-screwdriver-wrench',   title: 'Technical SEO',         description: 'Crawlability, indexation, Core Web Vitals (LCP, INP, CLS), JavaScript rendering, LocalBusiness structured data and HTTPS hardening — the technical SEO foundation every contractor website needs to rank.' },
  { icon: 'fa-pen-fancy',            title: 'Content & on-page',     description: 'Topical clusters, internal linking, search-intent matching, E-E-A-T signals and content SEO for HVAC and plumbing companies, built around how homeowners search for services.' },
  { icon: 'fa-link',                 title: 'Authority & links',     description: 'White-hat digital PR, niche edits, partnerships and unlinked-mention reclamation for home service brands — link building for home service businesses done right. No PBNs, no spam.' },
  { icon: 'fa-robot',                title: 'AI search (GEO)',       description: 'AI search optimization for home service companies across Google AI Overviews, ChatGPT Search, Perplexity and Bing Copilot — so your company gets cited when AI recommends contractors nearby.' },
  { icon: 'fa-chart-mixed',          title: 'Reporting & analytics', description: 'GA4, GSC, CrUX field data and call tracking unified into one contractor SEO dashboard — monthly executive summaries tied to real leads and booked jobs, not just rankings.' },
];

const stats = [
  { stat: '53%', label: 'of all U.S. website traffic comes from organic search — making SEO the highest-volume lead channel available to home service companies' },
  { stat: '#1',  label: "organic result earns ~28% click-through rate — that's the position your HVAC or plumbing business should own for every key service search in your area" },
  { stat: '46%', label: 'of Google searches have local intent — nearly half of all searches are from homeowners actively looking for a contractor near them right now' },
  { stat: '93%', label: 'of online experiences begin with a search engine — your home service business needs to be visible at the very top before a homeowner ever picks up the phone' },
];

const localSeo = [
  { icon: 'fa-google',           title: 'Google Business Profile optimization', description: "Google Business Profile categories, services, posts, photos and Q&A — managed weekly to lift your home service company's map-pack rankings and drive direct calls." },
  { icon: 'fa-map-location-dot', title: 'Geo-grid rank tracking',                description: 'Track local SEO rankings across hundreds of points in your service area — so you know exactly where your home service business is winning and losing calls, not just one zip code.' },
  { icon: 'fa-id-card',          title: 'Citations & NAP',                       description: 'Audit and fix your contractor business listings across Apple Maps, Bing Places, Yelp, BBB and 50+ local data aggregators — NAP consistency is the foundation of local SEO for home service companies.' },
  { icon: 'fa-star',             title: 'Review generation',                     description: 'Automated review generation for home service contractors — FTC-compliant gating, monitoring and response templates that build the review velocity Google rewards with higher local rankings.' },
];

const technicalSeo = [
  { icon: 'fa-spider',          title: 'Crawl & index audit',   description: 'Identify wasted crawl budget, orphan service-area pages, indexation bloat and conflicting signals on your home service website — the issues silently suppressing your rankings.' },
  { icon: 'fa-bolt',            title: 'Core Web Vitals',       description: 'Real-user LCP, INP and CLS optimization tied to your CrUX field data — Core Web Vitals directly impact how Google ranks your home service website in 2026.' },
  { icon: 'fa-code-branch',     title: 'JS rendering & schema', description: 'Server-side rendering review, hydration audit and JSON-LD schema — including LocalBusiness and Service schema for rich results on contractor websites.' },
  { icon: 'fa-shield-halved',   title: 'Security & headers',    description: 'HTTPS, HSTS, CSP and modern security headers that protect homeowners visiting your site — and protect your rankings from security-related Google penalties.' },
];

const process = [
  { n: '01', title: 'Audit',     desc: 'A report presentation of technical, content and link audit of your home service website against your top 3 local competitors — identifying exactly what is keeping your business off page one.', icon: 'fa-magnifying-glass' },
  { n: '02', title: 'Strategy',  desc: 'A 12-month SEO roadmap for your home service business — technical fixes, service-area content clusters, Google Business Profile strategy and link-building targets.',  icon: 'fa-route' },
  { n: '03', title: 'Execute',   desc: 'Developers, SEO writers and outreach specialists working in 2-week sprints on your contractor website — fixing, publishing and building every fortnight with weekly progress notes.', icon: 'fa-gears' },
  { n: '04', title: 'Measure',   desc: 'Live contractor SEO dashboard with rankings, traffic, leads and booked jobs — reviewed in monthly working sessions so you always know exactly what the SEO program is delivering.', icon: 'fa-chart-line' },
];

const faqs = [
  { q: 'How long until SEO starts working?',
    a: "For home service companies, local SEO and technical wins often show inside 60–90 days. Sustained organic traffic growth for HVAC, plumbing and home service contractors typically lifts in months 3–6, with compounding gains beyond month 6. We share weekly leading indicators — rankings, impressions, indexation — so you're never in the dark." },
  { q: 'Do you guarantee #1 rankings?',
    a: 'No reputable home service SEO agency guarantees #1 rankings — Google explicitly forbids that promise. What we do guarantee: an experienced team that knows the trades, a transparent 12-month roadmap and reporting that ties every deliverable to traffic, leads and booked jobs.' },
  { q: 'What about Google AI Overviews and ChatGPT?',
    a: 'AI search optimization for home service companies is built into every plan. We optimize your content for citation-grade quality so your HVAC or home improvement business gets recommended by Google AI Overviews, ChatGPT Search, Claude, Perplexity and other AI search platforms — and we implement llms.txt where appropriate.' },
  { q: 'Will you fix my site or just hand me a list?',
    a: "Our SEO sprints include developers, content writers and outreach specialists. Recommendations don't sit in a report; they get implemented on your home service website within the sprint they're assigned." },
  { q: 'Do you use white-hat link building?',
    a: 'Always — link building for home service businesses is done exclusively through digital PR, niche edits and editorial partnerships. Every link comes from a site with real traffic and real standards. No PBNs, no link schemes, no shortcuts that put your contractor website at risk of a Google penalty.' },
];

const faqSchemaItems = faqs.map((faq) => ({ question: faq.q, answer: faq.a }));

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${SITE.url}/search-engine-optimization/#service`,
  name: 'SEO for Home Service Companies',
  serviceType: 'Search Engine Optimization',
  description: 'Local SEO, technical SEO, content SEO, authority building and AI search optimization for HVAC, plumbing and home service contractors.',
  provider: { '@id': `${SITE.url}#organization` },
  areaServed: { '@type': 'Country', name: 'United States' },
  audience: {
    '@type': 'Audience',
    audienceType: 'HVAC, plumbing, electrical, roofing and home service contractors',
  },
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE.url}#localbusiness`,
  name: SITE.fullName,
  alternateName: SITE.name,
  url: SITE.url,
  logo: new URL(SITE.logo, SITE.url).toString(),
  image: new URL(SITE.logo, SITE.url).toString(),
  telephone: SITE.phone,
  email: SITE.email,
  priceRange: '$$',
  openingHours: 'Mo-Fr 08:00-17:00',
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.state,
    postalCode: SITE.address.zip,
    addressCountry: 'US',
  },
  areaServed: { '@type': 'Country', name: 'United States' },
  sameAs: Object.values(SITE.social),
};
---

<BaseLayout
  title="SEO for Home Service Companies | Local & National | PrintFast"
  appendSiteName={false}
  description="Local SEO, technical SEO and content for HVAC, plumbing & home service contractors. Map pack, organic rankings and AI search — managed by a senior U.S. team."
  keywords={[
    'SEO for home service companies',
    'local SEO for contractors',
    'home service SEO agency',
    'HVAC SEO services',
    'plumbing SEO agency',
    'contractor SEO company',
    'local SEO for HVAC companies',
    'Google Business Profile optimization for contractors',
    'SEO for home service businesses that generates leads',
    'technical SEO for contractor websites',
    'local map pack SEO for home service',
    'AI search optimization for home service companies',
    'Google AI Overviews for contractors',
    'link building for home service businesses',
    'content SEO for HVAC and plumbing companies',
    'geo-grid rank tracking for home service',
    'review generation for home service contractors',
    'SEO audit for contractor website',
  ]}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Services', href: '/#services' },
    { name: 'Search Engine Optimization', href: '/search-engine-optimization/' },
  ]}
  faqs={faqSchemaItems}
  schema={[serviceSchema, localBusinessSchema]}
>
  <Hero
    variant="service"
    eyebrow="Search Engine Optimization"
    title="SEO for Home Service Companies — Win Google, Bing &"
    highlight="AI Search"
    description="SEO that wins Google, Bing and AI search for home service companies — from map pack to organic rankings to AI Overviews. Our team handles the audit, the engineering, the content and the links — so your HVAC, plumbing, electrical or home improvement business shows up first when ready-to-buy customers search."
    primaryCta={{ label: 'Request an SEO Proposal', href: '/contact-us/' }}
    secondaryCta={{ label: 'Talk to a strategist', href: '#contact' }}
    trustItems={['No long-term contracts', 'Specialists in Home Service SEO', 'Free strategy call for contractors']}
  />

  <!-- Stats -->
  <section class="section-tight">
    <div class="container-pf">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {stats.map((s) => (
          <div class="card p-7 text-center" data-reveal>
            <p class="font-display text-4xl font-extrabold gradient-text">{s.stat}</p>
            <p class="mt-2 text-sm text-ink-600">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pillars -->
  <section class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Our SEO disciplines"
        title="Our Home Service SEO Disciplines — The Full Stack, Built to Drive Leads"
        description="We don't pick a lane. For home service companies, local, technical, content, links and AI search only work when they work together — and we manage all of them."
      />
      <div class="mt-14">
        <FeatureGrid items={pillars} columns={3} />
      </div>
    </div>
  </section>

  <!-- Local SEO deep dive -->
  <section class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Local SEO"
        title="Local SEO for Home Service Contractors — Owning the Map Pack in Your Service Area"
        description="46% of Google searches have local intent. We help HVAC, plumbing, electrical and home improvement contractors win the three map pack results that drive the most inbound calls."
      />
      <div class="mt-14">
        <FeatureGrid items={localSeo} columns={4} />
      </div>
    </div>
  </section>

  <!-- Technical SEO deep dive -->
  <section class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Technical SEO"
        title="Technical SEO for Contractor Websites — Engineering the Foundation Google Rewards"
        description="Most rankings problems for home service websites are technical. We fix the foundation before adding more content or links — because no amount of content will rank on a technically broken contractor website."
      />
      <div class="mt-14">
        <FeatureGrid items={technicalSeo} columns={4} />
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section">
    <div class="container-pf">
      <div class="grid lg:grid-cols-12 gap-10 items-start">
        <div class="lg:col-span-5">
          <p class="eyebrow"><i class="fa-solid fa-bolt text-brand-600"></i> How we work</p>
          <h2 class="heading-lg mt-4">How We Do Home Service SEO — A Predictable Engagement, End to End</h2>
          <p class="lead mt-5">
            Every home service SEO engagement starts with the same four phases — and a 12-month roadmap tied to real lead metrics you can hold us to.
          </p>
          <a href="/contact-us/" class="btn-primary mt-8">Talk to a strategist</a>
        </div>
        <ol class="lg:col-span-7 grid sm:grid-cols-2 gap-5">
          {process.map((p) => (
            <li class="card p-6" data-reveal>
              <div class="flex items-center justify-between">
                <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600">
                  <i class:list={['fa-solid', p.icon]}></i>
                </span>
                <span class="text-xs font-mono text-ink-400">{p.n}</span>
              </div>
              <h3 class="mt-4 text-lg font-bold text-ink-900">{p.title}</h3>
              <p class="mt-2 text-sm text-ink-600">{p.desc}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container-pf max-w-4xl">
      <SectionHeading eyebrow="FAQs" title="Common Questions About Our Home Service SEO Services" />
      <div class="mt-10 space-y-3">
        {faqs.map((f) => (
          <details class="group card p-6 transition-colors hover:ring-brand-200">
            <summary class="flex cursor-pointer items-center justify-between gap-4 list-none">
              <span class="font-semibold text-ink-900">{f.q}</span>
              <i class="fa-solid fa-plus text-ink-400 group-open:rotate-45 transition-transform"></i>
            </summary>
            <p class="mt-4 text-ink-600 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Testimonials />

  <ClientLogos
    eyebrow="SEO clients"
    title="Trusted by brands ranking nationwide"
    description="Some of the U.S. home service companies relying on PrintFast for organic growth."
    background="muted"
  />

  <CTA
    eyebrow="SEO for Home Service Companies"
    title="Work With a Home Service SEO Agency That Generates Leads."
    description="Tell us your site, service area and top competitors — we'll come back with an SEO audit for your contractor website and a 12-month roadmap for SEO for home service businesses that generates leads."
    primaryCta={{ label: 'Request an SEO Proposal', href: '/contact-us/' }}
    secondaryCta={{ label: 'Talk to a strategist', href: '#contact' }}
  />

  <section id="contact" class="section">
    <div class="container-pf max-w-4xl">
      <ContactForm
        title="Talk to our SEO team"
        subtitle="Share your site, top keywords and goals — we'll respond within one business day."
      />
    </div>
  </section>
</BaseLayout>
