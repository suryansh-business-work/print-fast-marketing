---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import SectionHeading from '@components/SectionHeading.astro';
import FeatureGrid from '@components/FeatureGrid.astro';
import ServiceCard from '@components/ServiceCard.astro';
import Testimonials from '@components/Testimonials.astro';
import CTA from '@components/CTA.astro';
import ContactForm from '@components/ContactForm.astro';

const reasons = [
  { icon: 'fa-lightbulb', title: 'Creative expertise for home services', description: 'Story-driven videos for plumbing, HVAC, cleaning, landscaping and more — built to convert.' },
  { icon: 'fa-microchip', title: 'AI-powered video creation', description: 'AI-assisted scripting and insights deliver high-quality content faster, with smarter results.' },
  { icon: 'fa-tags', title: 'Cost-effective & versatile', description: 'Affordable production without compromise. Flexible packages that flex with your business.' },
  { icon: 'fa-bullseye', title: 'Higher engagement rates', description: 'Built to capture attention — expect stronger click-throughs, recall and conversions.' },
  { icon: 'fa-tower-broadcast', title: 'Multi-channel usability', description: 'Optimized for site, social, email and ads so the message stays consistent everywhere.' },
];

const process = [
  { title: 'Scoping & brainstorming', icon: 'fa-comments', description: 'We understand your goals, audience and brand. Then we explore concepts that resonate.' },
  { title: 'Scripting', icon: 'fa-pen-fancy', description: 'A tight, conversion-aware script with the right hook, story arc and CTA for the channel.' },
  { title: 'Video production', icon: 'fa-clapperboard', description: 'Capture, edit, sound, motion graphics — delivered in formats ready for every platform.' },
];

const formats = [
  { title: 'Brand stories', icon: 'fa-heart-pulse', description: '60–90s anchor videos that introduce your team, values and process.', href: '#contact', cta: 'See examples' },
  { title: 'Service explainers', icon: 'fa-screwdriver-wrench', description: 'Walkthrough videos that turn confused shoppers into confident buyers.', href: '#contact', cta: 'See examples' },
  { title: 'Social shorts & reels', icon: 'fa-mobile-screen-button', description: 'Vertical, fast-cut, hook-first content optimized for TikTok, Reels and Shorts.', href: '#contact', cta: 'See examples' },
  { title: 'Customer testimonials', icon: 'fa-quote-left', description: 'Authentic stories from happy customers, edited for maximum trust.', href: '#contact', cta: 'See examples' },
  { title: 'Ad creative', icon: 'fa-megaphone', description: 'Multi-variant ad cuts engineered to perform on Meta, YouTube and Google.', href: '#contact', cta: 'See examples' },
  { title: 'Email & site loops', icon: 'fa-envelope-open-text', description: 'Lightweight loops and embeds that lift conversion on landing pages and emails.', href: '#contact', cta: 'See examples' },
];
---

<BaseLayout
  title="Video Marketing"
  description="Custom video production for home-service brands. Story-led, AI-accelerated videos optimized for sites, social, ads and email."
  keywords={[
    'video marketing',
    'video production for HVAC',
    'plumbing video marketing',
    'video ads for contractors',
    'social video production',
    'AI video creation',
  ]}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Video Marketing', href: '/video-marketing/' },
  ]}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: 'Video Marketing & Production',
    provider: { '@type': 'Organization', name: 'Print Fast Digital Marketing' },
    areaServed: 'United States',
  }}
>
  <Hero
    variant="service"
    eyebrow="Video Marketing"
    title="Show up, stand out,"
    highlight="and sell with story."
    description="Custom video production is the heartbeat of compelling digital storytelling. PrintFast helps you transform your core message into a dynamic visual experience — videos perfectly suited to captivate viewers on your site, in email and across social."
    primaryCta={{ label: 'Start a Video Project', href: '#contact' }}
    secondaryCta={{ label: 'See our process', href: '#process' }}
  />

  <section class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Why PrintFast"
        title="Why choose us for video marketing?"
        description="A specialist team that understands trade-service buyers and the platforms they live on."
      />
      <div class="mt-14">
        <FeatureGrid items={reasons} columns={3} />
      </div>
    </div>
  </section>

  <section id="process" class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="How we work"
        title="A 3-step efficient video-creation process"
        description="A streamlined workflow that respects your time and your budget — without cutting creative corners."
      />
      <div class="mt-14 grid gap-6 lg:grid-cols-3">
        {process.map((p, i) => (
          <ServiceCard
            icon={p.icon}
            title={`${i + 1}. ${p.title}`}
            description={p.description}
            number={String(i + 1).padStart(2, '0')}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Formats we produce"
        title="Video for every channel and goal"
        description="From brand-defining hero videos to high-velocity social cuts — we cover the whole funnel."
      />
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {formats.map((f) => <ServiceCard {...f} />)}
      </div>
    </div>
  </section>

  <Testimonials />

  <CTA
    eyebrow="Let's create together"
    title="Not sure how video marketing can help your business?"
    description="Schedule a free consultation with our marketing experts. We'll demonstrate the impact video can have on your next campaign."
    primaryCta={{ label: 'Schedule a Call', href: '#contact' }}
    secondaryCta={{ label: 'Get a Free Digital Review', href: '/free-digital-review/' }}
  />

  <section id="contact" class="section">
    <div class="container-pf max-w-4xl">
      <ContactForm
        title="Tell us about your video project"
        subtitle="Brief, timeline, channels — share what you have and we'll suggest the right approach."
      />
    </div>
  </section>
</BaseLayout>
