---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import SectionHeading from '@components/SectionHeading.astro';
import FeatureGrid from '@components/FeatureGrid.astro';
import PricingCard from '@components/PricingCard.astro';
import Testimonials from '@components/Testimonials.astro';
import CTA from '@components/CTA.astro';
import ContactForm from '@components/ContactForm.astro';

const reasons = [
  { icon: 'fa-network-wired', title: 'Multi-network reach', description: 'Publish, manage and monitor posts seamlessly across every major platform from one place.' },
  { icon: 'fa-wand-magic-sparkles', title: 'Tailored per platform', description: 'From Instagram Reels to LinkedIn carousels — content shaped for the channel that\'s viewing it.' },
  { icon: 'fa-calendar-days', title: 'Visual content calendar', description: 'A holistic view of your strategy so nothing slips and every campaign stays cohesive.' },
  { icon: 'fa-layer-group', title: 'Bulk scheduling', description: 'Queue up to 500 posts in one go across multiple accounts to keep momentum effortless.' },
  { icon: 'fa-leaf', title: 'Evergreen content library', description: 'Store best-performing posts and hashtag sets for instant, reliable reuse.' },
  { icon: 'fa-robot', title: 'AI-assisted creation', description: 'Smart drafts that accelerate publishing while staying on-brand for the trades.' },
];

const channels = [
  { name: 'Facebook', icon: 'fa-facebook' },
  { name: 'Instagram', icon: 'fa-instagram' },
  { name: 'YouTube', icon: 'fa-youtube' },
  { name: 'LinkedIn', icon: 'fa-linkedin' },
  { name: 'X / Twitter', icon: 'fa-x-twitter' },
  { name: 'TikTok', icon: 'fa-tiktok' },
  { name: 'Tumblr', icon: 'fa-tumblr' },
  { name: 'Pinterest', icon: 'fa-pinterest' },
  { name: 'Google', icon: 'fa-google' },
];

const plans = [
  {
    name: 'Starter',
    price: '$99',
    description: 'Get a consistent presence on the channels that matter most.',
    features: [
      '24 custom posts / month',
      'Up to 4 platforms',
      'Content tuned for engagement',
      '12 social accounts (per brand)',
      'Bulk scheduling & calendar view',
      'Customize per platform, first comment',
      'URL shortener & UTM parameters',
      '5 user licenses',
    ],
    cta: { label: 'Start with Starter', href: '#contact' },
  },
  {
    name: 'Essentials',
    price: '$345',
    description: 'Our most popular plan — built for steady growth.',
    popular: true,
    features: [
      '8 high-quality custom posts / month',
      'Up to 4 platforms (extra at $9.95 ea)',
      'Content focused on driving results',
      '3 social accounts (per brand)',
      'Schedule, bulk upload & calendar',
      'GIF, video & carousel support',
      'Custom CTAs and detailed analytics',
      'PDF reports + Zapier integration',
    ],
    cta: { label: 'Choose Essentials', href: '#contact' },
  },
  {
    name: 'Premium',
    price: '$495',
    description: 'For brands serious about owning their category online.',
    features: [
      '12 custom posts / month',
      'Advanced keyword & hashtag analysis',
      '5 social accounts (per brand)',
      '2 RSS-fed scheduled posts',
      'Smart queues & approval workflows',
      'Slack, Canva & Drive integrations',
      'Schedule reports + post-performance',
      'Priority customer support',
    ],
    cta: { label: 'Go Premium', href: '#contact' },
  },
];
---

<BaseLayout
  title="Managed Social Media for Home-Service Brands"
  description="Done-for-you social media for HVAC, plumbing and electrical pros. Multi-network publishing, content creation, scheduling, analytics and AI-assisted posts."
  keywords={[
    'managed social media',
    'social media marketing for HVAC',
    'plumbing social media',
    'social media for contractors',
    'social media management agency',
    'Facebook marketing trades',
    'Instagram marketing trades',
  ]}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Managed Social Media', href: '/managed-social-media/' },
  ]}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: 'Managed Social Media Marketing',
    provider: { '@type': 'Organization', name: 'Print Fast Digital Marketing' },
    areaServed: 'United States',
    offers: [
      { '@type': 'Offer', name: 'Starter', price: '99', priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Essentials', price: '345', priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Premium', price: '495', priceCurrency: 'USD' },
    ],
  }}
>
  <Hero
    variant="service"
    eyebrow="Managed Social Media"
    title="Social media that"
    highlight="grows your trade brand."
    description="In the busy world of HVAC, plumbing and electrical services, staying ahead demands a real digital strategy. PrintFast's state-of-the-art managed social service elevates your reach, engagement and growth — without you lifting a finger."
    primaryCta={{ label: 'See pricing', href: '#pricing' }}
    secondaryCta={{ label: 'Talk to us', href: '#contact' }}
  />

  <section class="section-tight">
    <div class="container-pf">
      <SectionHeading title="Channels we manage" eyebrow="Where you'll show up" />
      <div class="mt-10 flex flex-wrap justify-center gap-4 sm:gap-6">
        {channels.map((c) => (
          <span class="flex items-center gap-2 rounded-full bg-white px-4 py-2.5 ring-1 ring-ink-100 shadow-soft text-ink-700 text-sm">
            <i class:list={['fa-brands', c.icon, 'text-brand-600']}></i>
            {c.name}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Why PrintFast"
        title="Why choose us for social media marketing?"
        description="A platform plus a team — built specifically for the home-service industry."
      />
      <div class="mt-14">
        <FeatureGrid items={reasons} columns={3} />
      </div>
    </div>
  </section>

  <section id="pricing" class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Plans for your growth"
        title="Choose the plan that fits"
        description="All plans are month-to-month. Need something custom? We'll build it with you."
      />
      <div class="mt-14 grid gap-6 lg:grid-cols-3">
        {plans.map((p) => <PricingCard {...p} />)}
      </div>
      <p class="mt-8 text-center text-sm text-ink-500">
        All plans billed monthly. <span class="font-semibold text-brand-700">Save 10% annually.</span>
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-pf">
      <div class="card p-8 lg:p-12 grid gap-8 lg:grid-cols-2 items-center">
        <div>
          <p class="eyebrow"><i class="fa-solid fa-bolt"></i> Experience the growth</p>
          <h2 class="heading-md mt-4">Experience unparalleled growth with PrintFast</h2>
          <p class="mt-4 text-ink-600 leading-relaxed">
            PrintFast empowers your HVAC, plumbing or electrical service company to thrive in the digital landscape.
            Our managed social media service harnesses the latest tools and strategies to drive engagement, leads and real business growth.
          </p>
          <a href="#contact" class="btn-primary mt-6">Schedule a Call</a>
        </div>
        <ul class="check-list space-y-3">
          <li>Dedicated content strategist for your brand</li>
          <li>Editorial calendar tailored to your busy season</li>
          <li>Reels, shorts, carousels and stories — covered</li>
          <li>Comment moderation & community engagement</li>
          <li>Monthly performance reviews with next steps</li>
        </ul>
      </div>
    </div>
  </section>

  <Testimonials />

  <CTA
    eyebrow="Ready to amplify?"
    title="Take control of your social presence today."
    description="Don't let your competitors dominate the conversation. Our team will plan, create and publish so your brand stays top of mind."
    primaryCta={{ label: 'Book a Free Call', href: '#contact' }}
    secondaryCta={{ label: 'Get a Free Digital Review', href: '/free-digital-review/' }}
  />

  <section id="contact" class="section">
    <div class="container-pf max-w-4xl">
      <ContactForm
        title="Connect with our social team"
        subtitle="Tell us about your goals — we'll send a tailored plan within one business day."
      />
    </div>
  </section>
</BaseLayout>
