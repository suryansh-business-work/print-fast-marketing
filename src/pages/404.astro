---
import BaseLayout from '@layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found" description="The page you were looking for doesn't exist." noindex>
  <section class="section text-center">
    <div class="container-pf max-w-2xl">
      <p class="eyebrow mx-auto"><i class="fa-solid fa-triangle-exclamation"></i> 404</p>
      <h1 class="heading-xl mt-5">We couldn't find that page.</h1>
      <p class="lead mt-5">
        It may have moved, or the link might be wrong. Head back home or jump to one of our services.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/" class="btn-primary">Back to Home</a>
        <a href="/free-digital-review/" class="btn-outline">Get a Free Review</a>
      </div>
    </div>
  </section>
</BaseLayout>
