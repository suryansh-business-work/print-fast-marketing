---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import SectionHeading from '@components/SectionHeading.astro';
import FeatureGrid from '@components/FeatureGrid.astro';
import Testimonials from '@components/Testimonials.astro';
import CTA from '@components/CTA.astro';
import ContactForm from '@components/ContactForm.astro';

const inside = [
  { icon: 'fa-magnifying-glass-chart', title: 'SEO analysis', description: 'A detailed look at your site\'s current search performance and biggest growth opportunities.' },
  { icon: 'fa-pen-ruler', title: 'Content evaluation', description: 'Quality vs quantity — what to keep, what to retire, and where to invest next.' },
  { icon: 'fa-map-location-dot', title: 'Local search optimization', description: 'Specific recommendations to gain the edge in your service-area community.' },
  { icon: 'fa-chess-knight', title: 'Competitive landscape', description: 'See exactly how you measure up against the local competitors winning today.' },
];

const why = [
  { icon: 'fa-trophy', title: '#1 SEO expert for the trades', description: 'Years of focused work delivering results for HVAC, plumbing and electrical businesses.' },
  { icon: 'fa-chart-pie', title: 'Data-driven strategies', description: 'Every recommendation backed by real search data — no vibes, no guesswork.' },
  { icon: 'fa-handshake', title: 'No strings attached', description: 'The Digital Review Report is yours to keep, even if we never work together.' },
];
---

<BaseLayout
  title="Free Digital Review"
  description="Claim your free Digital Review Report — a comprehensive SEO, content, local and competitor analysis tailored for HVAC, plumbers and electricians."
  keywords={[
    'free SEO audit',
    'free digital marketing review',
    'website audit',
    'competitor analysis',
    'local SEO audit',
    'HVAC SEO audit',
  ]}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Free Digital Review', href: '/free-digital-review/' },
  ]}
  faqs={[
    { question: 'What is included in the Free Digital Review?', answer: 'A comprehensive SEO analysis, content evaluation, local search optimization audit, and a full competitive landscape report tailored to your business.' },
    { question: 'How long does it take to receive my report?', answer: 'You will receive your custom Digital Review Report within 2 business days of submitting the form.' },
    { question: 'Is there really no cost?', answer: 'Yes — the Digital Review Report and the 1:1 strategy consultation (a $200 value) are completely free, with no obligation.' },
    { question: 'Do I need to sign a contract afterwards?', answer: 'Never. The report is yours to keep and act on, whether you choose to work with PrintFast or not.' },
  ]}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Offer',
    name: 'Free Digital Review Report + 1:1 Consultation',
    price: '0',
    priceCurrency: 'USD',
    availability: 'https://schema.org/InStock',
    seller: { '@type': 'Organization', name: 'Print Fast Digital Marketing' },
  }}
>
  <Hero
    variant="service"
    eyebrow="Free Digital Review"
    title="Get a free review of"
    highlight="your website."
    description="A Digital Review Report is a comprehensive analysis of your site, your competitors and your market. Tailored for HVAC pros, plumbers and electricians, it gives you a foolproof plan to enhance your local reach."
    primaryCta={{ label: 'Claim My Free Review', href: '#claim' }}
    secondaryCta={{ label: 'See what\'s included', href: '#inside' }}
  />

  <section id="inside" class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="What's inside the report"
        title="A complete picture of your digital footprint"
        description="Every section is hand-prepared by a senior strategist — not auto-generated."
      />
      <div class="mt-14">
        <FeatureGrid items={inside} columns={4} />
      </div>
    </div>
  </section>

  <section class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Why PrintFast"
        title="Why choose PrintFast for your review?"
        description="With PrintFast, you're choosing the team that understands the nuances of HVAC, plumbing and electrical industries like no other."
      />
      <div class="mt-14">
        <FeatureGrid items={why} columns={3} />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-pf">
      <div class="card p-8 lg:p-12 grid gap-8 lg:grid-cols-2 items-center">
        <div>
          <p class="eyebrow"><i class="fa-solid fa-gift"></i> Limited-time bonus</p>
          <h2 class="heading-md mt-4">Plus a free 1:1 strategy consultation — a $200 value.</h2>
          <p class="mt-4 text-ink-600 leading-relaxed">
            For a limited time, every Digital Review includes a personal 1:1 walk-through with a senior strategist
            who'll dissect your report, answer questions and outline next steps. Yours to keep, no strings attached.
          </p>
          <a href="#claim" class="btn-primary mt-6">Claim My Free Review</a>
        </div>
        <ul class="check-list space-y-3">
          <li>Comprehensive SEO and content analysis</li>
          <li>Local search and Google Business audit</li>
          <li>Top 3 competitor benchmarking</li>
          <li>Personalized 30-min strategy call</li>
          <li>Action plan you can execute with anyone</li>
        </ul>
      </div>
    </div>
  </section>

  <Testimonials />

  <CTA
    eyebrow="Claim your free review"
    title="See your site's full potential — no cost, no commitment."
    description="Complete the form below to claim your Free Digital Review Report and your additional consultation now."
    primaryCta={{ label: 'Get My Free Review', href: '#claim' }}
    secondaryCta={{ label: 'Talk to us', href: '/managed-social-media/' }}
  />

  <section id="claim" class="section">
    <div class="container-pf max-w-4xl">
      <ContactForm
        variant="review"
        title="Claim your free Digital Review"
        subtitle="Drop your details below — we'll send your custom report within 2 business days."
      />
    </div>
  </section>
</BaseLayout>
