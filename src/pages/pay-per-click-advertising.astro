---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import SectionHeading from '@components/SectionHeading.astro';
import FeatureGrid from '@components/FeatureGrid.astro';
import PricingCard from '@components/PricingCard.astro';
import Testimonials from '@components/Testimonials.astro';
import CTA from '@components/CTA.astro';
import ContactForm from '@components/ContactForm.astro';
import { getContactHref } from '@data/pricing';
import ClientLogos from '@components/ClientLogos.astro';
import { SITE } from '@data/site';

const channels = [
  { icon: 'fa-google',          title: 'Google Ads — Search',        description: 'High-intent Google Ads campaigns targeting the queries that book HVAC tune-ups, emergency plumbing calls and home service jobs. Single-keyword ad groups, exhaustive negative lists and automated bid strategies tied to real cost-per-lead targets.' },
  { icon: 'fa-shop',            title: 'Google Local Services Ads',  description: "Pay-per-lead campaigns with Google-Guaranteed badge setup, license & insurance verification, and dispute management — engineered for U.S. home service area businesses seeking the top position in Google's local pack." },
  { icon: 'fa-bullseye',        title: 'Performance Max & Demand Gen', description: 'AI-driven Performance Max campaigns with expert manual guardrails: brand exclusions, intent-segmented asset groups and signal-rich audience lists built from your CRM data — preventing wasted spend common in automated-only setups.' },
  { icon: 'fa-meta',            title: 'Meta Ads (Facebook & Instagram)', description: 'Conversion-API-powered Meta advertising campaigns with creative testing frameworks, lookalike audiences and zip-code targeting — reaching homeowners in your service area before they hit Google.' },
  { icon: 'fa-youtube',         title: 'YouTube Ads',                description: 'Skippable, bumper and YouTube Shorts campaigns engineered to build brand awareness among homeowners and drive direct response — remarketing to visitors who researched HVAC or plumbing services.' },
  { icon: 'fa-microsoft',       title: 'Microsoft (Bing) Ads',       description: 'Bing Ads often deliver 30–50% cheaper cost-per-click than Google for the same contractor search intent — especially among homeowners 35+. We import, restructure and actively optimize for this underutilized channel.' },
  { icon: 'fa-tiktok',          title: 'TikTok Ads',                 description: 'Spark Ads, native lead-gen forms and creative-led video campaigns that put your home service brand in front of local homeowners on the fastest-growing local discovery platform.' },
  { icon: 'fa-list',            title: 'LinkedIn & B2B',             description: 'Account-based LinkedIn advertising, lead-gen form campaigns and CRM integration for commercial HVAC, roofing and facility-maintenance contractors targeting property managers, HOAs and commercial decision-makers.' },
];

const stats = [
  { stat: '$2+',  label: 'average return for every $1 spent on Google Search Ads — across home service accounts managed by PrintFast' },
  { stat: '7×',   label: 'higher conversion rate when call tracking for contractors is fully integrated with Google Ads and CRM' },
  { stat: '4.4×', label: 'lower cost per lead (CPL) on properly structured Google Local Services Ads (LSA) vs. standard Search alone' },
  { stat: '<48h', label: 'typical time-to-launch for a new PPC management account — from signed agreement to live campaigns' },
];

const whatYouGet = [
  { icon: 'fa-folder-tree',     title: 'Account architecture',    description: 'Google Ads and Meta account architecture built for home service clarity and scale: logical campaign hierarchies, audience segmentation by service line and naming conventions your team can actually read — no spaghetti accounts.' },
  { icon: 'fa-pen-fancy',       title: 'Creative & copy',          description: 'Responsive Search Ad (RSA) headlines and descriptions, display image creative and short-form video — all produced in-house by our paid-media team. Every asset is tested and optimized for your home service audience.' },
  { icon: 'fa-flask',           title: 'Continuous testing',       description: 'Weekly creative, audience and bid strategy experiments — every winning variation is scaled, every underperformer is cut, and every test result is logged in your shared optimization log.' },
  { icon: 'fa-display',         title: 'Landing-page CRO',         description: 'Dedicated, speed-optimized landing pages for each campaign with form submission, phone call and live chat tracking built in. Our clients see an average 35–80% lift in conversion rate after switching from generic website pages.' },
  { icon: 'fa-phone-volume',    title: 'Call tracking & CRM',      description: 'CallRail or WhatConverts setup with dynamic number insertion, call scoring and recording, Meta Conversion API and CRM sync with HubSpot, Salesforce or ServiceTitan — so every inbound call is tied to the ad that drove it.' },
  { icon: 'fa-shield-halved',   title: 'Click-fraud protection',   description: 'Live filtering of bot traffic, competitor clicks and accidental clicks via ClickCease or Clickguard — so your home service ad budget reaches real homeowners searching for your services, not wasted impressions.' },
  { icon: 'fa-chart-line',      title: 'Attribution & reporting',  description: 'GA4 setup with server-side tagging, offline conversion import and a single real-time dashboard tying every dollar of ad spend to revenue — so you always know your true cost per booked job.' },
  { icon: 'fa-handshake',       title: 'Transparent fees',         description: 'You own every ad account and every data point. Ad spend is billed directly by Google, Meta and Microsoft to your card — never marked up by us. Our management fee is the only cost you pay PrintFast.' },
];

const process = [
  { n: '01', title: 'Audit & forecast', desc: 'A comprehensive audit of your existing Google Ads, LSA and Meta accounts plus a custom media plan with realistic cost-per-lead (CPL) and cost-per-acquisition (CPA) forecasts for your specific home service market and geography.', icon: 'fa-magnifying-glass-chart' },
  { n: '02', title: 'Build',            desc: 'Google Ads campaigns, LSA profiles, conversion tracking, call-tracking integration, dedicated landing pages and all ad creative — built inside your owned accounts by our senior paid-media team within 7 business days of kickoff.',  icon: 'fa-screwdriver-wrench' },
  { n: '03', title: 'Launch & learn',   desc: 'Controlled soft launch followed by a structured 14-day machine-learning phase to validate conversion signals, quality score and CPL benchmarks before scaling your home service ad spend.',              icon: 'fa-rocket' },
  { n: '04', title: 'Scale',            desc: 'Geographic expansion, audience scaling and creative production — paired with weekly A/B tests and monthly executive performance reviews that tie every PPC dollar to booked home service jobs.',                 icon: 'fa-arrow-trend-up' },
];

const plans = [
  {
    name: 'Starter PPC',
    price: '$899',
    description: 'For local businesses spending up to $5k/mo on ads.',
    features: [
      '1–2 channels (Google Search + LSA, or Meta)',
      'Account build + conversion tracking',
      '1 dedicated landing page',
      'Bi-weekly optimization sprints',
      'Call tracking with recording & scoring',
      'Monthly performance report',
    ],
    cta: { label: 'Start with Starter', href: getContactHref('pay-per-click-advertising', 'starter-ppc') },
  },
  {
    name: 'Growth PPC',
    price: '$1,899',
    description: 'Our most popular plan for multi-channel paid programs.',
    popular: true,
    features: [
      'Up to 4 channels',
      'Manages $5k–$30k / mo of ad spend',
      '3 landing pages + ongoing CRO',
      'Weekly optimization + creative tests',
      'GA4 + CRM + offline conversion import',
      'Monthly strategy call + dashboard',
    ],
    cta: { label: 'Choose Growth', href: getContactHref('pay-per-click-advertising', 'growth-ppc') },
  },
  {
    name: 'Scale PPC',
    price: '12% of spend',
    period: ' / mo',
    description: 'For brands spending $30k+ /mo who need a senior team in the seat.',
    features: [
      'All major paid channels',
      'Server-side tracking & attribution',
      'Dedicated paid-media lead + CRO designer',
      'Bi-weekly creative production',
      'Quarterly business review with finance',
      'SLA-backed reporting & response times',
    ],
    cta: { label: 'Scale with us', href: getContactHref('pay-per-click-advertising', 'scale-ppc') },
  },
];

const faqs = [
  { q: 'What is the minimum ad spend for home service PPC advertising?',
    a: 'For local Google Search Ads and Local Services Ads (LSA), we recommend a minimum of $1,500–$2,500/month of ad spend to gather enough conversion data for meaningful optimization. Below that threshold, home service SEO and email marketing typically deliver a stronger return on investment.',
    link: { label: 'Review PPC plans', href: '#pricing' } },
  { q: 'Do I own my Google Ads and Meta ad accounts when working with PrintFast?',
    a: "Yes — always. We build every campaign inside your Google Ads, Meta Business Manager, Microsoft Advertising and TikTok for Business accounts. You retain full admin access at all times and can revoke our access immediately if needed. There is no platform lock-in and no proprietary account structures you can't take with you.",
    link: { label: "See what's included", href: '#included' } },
  { q: 'Does PrintFast mark up ad spend or take a percentage of my Google Ads budget?',
    a: 'No — never. All ad spend is billed directly by Google, Meta, Microsoft and TikTok to your card. We never handle your ad budget or add a markup. The only payment you make to PrintFast is our transparent monthly PPC management fee.',
    link: { label: 'Compare pricing', href: '#pricing' } },
  { q: 'How quickly will I see leads from Google Ads and Local Services Ads?',
    a: "Google Search Ads and Local Services Ads (LSA) typically generate qualified contractor leads within 7–14 days of campaign launch. Meta Ads and YouTube campaigns generally take 3–4 weeks to fully optimize through the learning phase. We share weekly leading indicators — impressions, calls, CPL — so you're never in the dark.",
    link: { label: 'View the launch process', href: '#process' } },
  { q: 'Does PrintFast write the ad copy and design dedicated landing pages for our PPC campaigns?',
    a: 'Yes. Every PPC management plan includes professional ad copywriting, RSA asset creation, display and video creative production and dedicated landing page design optimized for home service conversions. You review and approve every piece of creative before it goes live — no surprises.',
    link: { label: "See what's included", href: '#included' } },
  { q: 'How does PrintFast protect my Google Ads budget from click fraud and bot traffic?',
    a: 'Yes. We deploy dedicated click-fraud protection software (ClickCease or Clickguard) on every Google Search and Display campaign, combined with ongoing IP exclusion lists, device-level exclusions and placement blacklisting for known bad actors — keeping your home service ad spend working for real homeowners, not bots.',
    link: { label: "See what's included", href: '#included' } },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${SITE.url}/pay-per-click-advertising/#service`,
  name: 'PPC Advertising for Home Service Contractors',
  serviceType: 'Pay-per-click management for home services',
  description: 'Google Ads, Local Services Ads, Meta Ads and Microsoft Ads management for home service contractors with call tracking, click-fraud protection, landing-page CRO and transparent ad spend management.',
  provider: { '@id': `${SITE.url}#organization` },
  areaServed: { '@type': 'Country', name: 'United States' },
  audience: {
    '@type': 'Audience',
    audienceType: 'HVAC, plumbing, roofing, electrical and home service contractors',
  },
  offers: [
    { '@type': 'Offer', name: 'Starter PPC', price: '899',  priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Growth PPC',  price: '1899', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Scale PPC',   priceSpecification: { '@type': 'PriceSpecification', priceCurrency: 'USD', description: '12% of monthly ad spend' } },
  ],
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE.url}#localbusiness`,
  name: SITE.fullName,
  alternateName: SITE.name,
  url: SITE.url,
  logo: new URL(SITE.logo, SITE.url).toString(),
  image: new URL(SITE.logo, SITE.url).toString(),
  telephone: SITE.phone,
  email: SITE.email,
  priceRange: '$$',
  openingHours: 'Mo-Fr 08:00-17:00',
  address: {
    '@type': 'PostalAddress',
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.state,
    postalCode: SITE.address.zip,
    addressCountry: 'US',
  },
  areaServed: { '@type': 'Country', name: 'United States' },
  sameAs: Object.values(SITE.social),
};
---

<BaseLayout
  title="PPC Advertising for Home Service Contractors | PrintFast"
  appendSiteName={false}
  description="Google Ads, LSAs, Meta & Microsoft PPC managed by a senior U.S. team. Click-fraud protection, call tracking and zero ad-spend markup for home service contractors."
  keywords={[
    'PPC advertising for home services',
    'Google Ads for contractors',
    'pay-per-click management for home services',
    'Google Local Services Ads management',
    'home service Google Ads agency',
    'PPC for HVAC contractors',
    'PPC for plumbers',
    'Meta Ads for home services',
    'click fraud protection for contractors',
    'call tracking for contractors',
    'local services ads LSA',
    'ad spend management',
    'landing page CRO',
    'Performance Max campaigns',
    'bid strategy optimization',
    'Google-Guaranteed badge',
    'PPC reporting dashboard',
    'cost per lead CPL for home services',
  ]}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Services', href: '/#services' },
    { name: 'Pay-Per-Click Advertising', href: '/pay-per-click-advertising/' },
  ]}
  schema={[serviceSchema, localBusinessSchema]}
>
  <Hero
    variant="service"
    eyebrow="Pay-Per-Click Advertising (PPC)"
    title="PPC advertising for home services tied to"
    highlight="real lead value — not vanity clicks."
    description="Our home service paid-media team manages Google Ads, Local Services Ads (LSAs), Meta ads, and Bing ads for HVAC, plumbing and home service contractors. You own the ad accounts, every data point and every dollar of ad spend — zero markup, zero lock-in."
    primaryCta={{ label: 'Get My Free PPC Proposal', href: '/contact-us/' }}
    secondaryCta={{ label: 'See pricing', href: '#pricing' }}
    trustItems={['No long-term contracts', 'Built for HVAC, Plumbing & Home Services', 'Free PPC strategy call']}
  />

  <section class="section bg-ink-50/60">
    <div class="container-pf">
      <div class="grid gap-10 lg:grid-cols-[1fr_460px] items-center">
        <div>
          <p class="eyebrow">PPC visual</p>
          <h2 class="heading-lg mt-4">Google Ads, LSAs, Meta and Bing — shown together in one animated program</h2>
          <p class="lead mt-5 text-ink-600">
            This animated vector visualization highlights the paid media stack for home service contractors: Google Search, Local Services Ads, Meta advertising and Bing. It shows how each platform feeds qualified calls, bookable jobs and measurable performance.
          </p>
        </div>
        <div class="overflow-hidden rounded-[2rem] bg-white p-6 shadow-soft ring-1 ring-ink-100">
          <svg viewBox="0 0 460 320" class="w-full">
            <rect x="18" y="28" width="180" height="110" rx="22" fill="#eef2ff" />
            <text x="108" y="72" text-anchor="middle" font-size="18" font-weight="800" fill="#0A66C2">Google Ads</text>
            <rect x="46" y="92" width="120" height="20" rx="10" fill="#fff" opacity="0.9" />
            <rect x="46" y="124" width="100" height="14" rx="7" fill="#fff" opacity="0.7" />
            <rect x="250" y="40" width="180" height="110" rx="22" fill="#f7f7fd" />
            <text x="340" y="72" text-anchor="middle" font-size="18" font-weight="800" fill="#1877F2">Meta Ads</text>
            <rect x="278" y="92" width="120" height="20" rx="10" fill="#fff" opacity="0.9" />
            <rect x="278" y="124" width="100" height="14" rx="7" fill="#fff" opacity="0.7" />
            <g class="animate-float delay-1">
              <circle cx="120" cy="226" r="30" fill="#34A853" />
              <text x="120" y="232" text-anchor="middle" font-size="14" font-weight="700" fill="#fff">LSA</text>
            </g>
            <g class="animate-float delay-2">
              <rect x="280" y="206" width="96" height="56" rx="18" fill="#008272" />
              <text x="328" y="236" text-anchor="middle" font-size="16" font-weight="700" fill="#fff">Bing</text>
            </g>
            <path d="M198 80c28-22 64-30 98-22" stroke="#0A66C2" stroke-width="4" fill="none" stroke-linecap="round" />
            <path d="M170 250c24-18 58-26 88-20" stroke="#34A853" stroke-width="4" fill="none" stroke-linecap="round" />
            <circle cx="325" cy="186" r="18" fill="#1877F2" opacity="0.25" />
            <circle cx="100" cy="140" r="14" fill="#F99B1C" opacity="0.35" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section-tight">
    <div class="container-pf">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {stats.map((s) => (
          <div class="card p-7 text-center" data-reveal>
            <p class="font-display text-4xl font-extrabold gradient-text">{s.stat}</p>
            <p class="mt-2 text-sm text-ink-600">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Channels -->
  <section id="channels" class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Channels we manage"
        title="Paid Advertising Channels We Manage for Home Service Contractors"
        description="Every PPC channel that drives qualified calls and booked jobs for HVAC, plumbing and home service businesses"
      />
      <p class="mx-auto mt-6 max-w-3xl text-center text-ink-600 leading-relaxed" data-reveal>
        We manage Google Ads, LSAs, Meta, Bing, YouTube and TikTok as one unified PPC management program — so your ad spend flows to the channel and creative that generates the lowest cost per lead this week.
      </p>
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {channels.map((c) => (
          <div class="card-hover p-6" data-reveal>
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600 text-lg">
              <i class:list={[c.icon === 'fa-meta' || c.icon === 'fa-google' || c.icon === 'fa-youtube' || c.icon === 'fa-microsoft' || c.icon === 'fa-tiktok' ? 'fa-brands' : 'fa-solid', c.icon]}></i>
            </span>
            <h3 class="mt-5 text-lg font-bold text-ink-900">{c.title}</h3>
            <p class="mt-2 text-sm text-ink-600 leading-relaxed">{c.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section id="included" class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="What's included"
        title="A complete PPC management operation — strategy, creative, tracking and attribution — not just campaign launches"
        description="Every PrintFast PPC management plan includes strategy, ad creative, conversion tracking, dedicated landing pages, CRO and full attribution reporting — all in one accountable engagement for home service contractors."
      />
      <div class="mt-14">
        <FeatureGrid items={whatYouGet} columns={4} />
      </div>
    </div>
  </section>

  <!-- Process -->
  <section id="process" class="section">
    <div class="container-pf">
      <div class="grid lg:grid-cols-12 gap-10 items-start">
        <div class="lg:col-span-5">
          <p class="eyebrow"><i class="fa-solid fa-bolt text-brand-600"></i> Our process</p>
          <h2 class="heading-lg mt-4">Our PPC Management Process</h2>
          <p class="lead mt-5">
            We never &ldquo;set and forget&rdquo; your Google Ads or LSA campaigns. Every home service PPC account runs on a documented weekly optimization cadence — and you see every change in a shared log.
          </p>
          <a href="/contact-us/" class="btn-primary mt-8">Talk to a paid-media lead</a>
        </div>
        <ol class="lg:col-span-7 grid sm:grid-cols-2 gap-5">
          {process.map((p) => (
            <li class="card p-6" data-reveal>
              <div class="flex items-center justify-between">
                <span class="grid h-11 w-11 place-items-center rounded-xl bg-brand-50 text-brand-600">
                  <i class:list={['fa-solid', p.icon]}></i>
                </span>
                <span class="text-xs font-mono text-ink-400">{p.n}</span>
              </div>
              <h3 class="mt-4 text-lg font-bold text-ink-900">{p.title}</h3>
              <p class="mt-2 text-sm text-ink-600">{p.desc}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Plans & pricing"
        title="Transparent management fees in USD"
        description="All plans are month-to-month. Ad spend is billed directly by the platforms to your card — never marked up."
      />
      <div class="mt-14 grid gap-6 lg:grid-cols-3">
        {plans.map((p) => <PricingCard {...p} />)}
      </div>
      <p class="mt-8 text-center text-sm text-ink-500">
        One-time setup fee starts at $750 (waived on annual prepay). <span class="font-semibold text-brand-700">Save 10% on annual prepay.</span>
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container-pf max-w-4xl">
      <SectionHeading eyebrow="FAQs" title="Frequently Asked Questions About PPC Advertising for Home Service Contractors" />
      <div class="mt-10 space-y-3">
        {faqs.map((f) => (
          <details class="group card p-6 transition-colors hover:ring-brand-200">
            <summary class="flex cursor-pointer items-center justify-between gap-4 list-none">
              <span class="font-semibold text-ink-900">{f.q}</span>
              <i class="fa-solid fa-plus text-ink-400 group-open:rotate-45 transition-transform"></i>
            </summary>
            <p class="mt-4 text-ink-600 leading-relaxed">{f.a}</p>
            {f.link && (
              <a href={f.link.href} class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-brand-700 hover:text-brand-800">
                {f.link.label} <i class="fa-solid fa-arrow-right text-xs"></i>
              </a>
            )}
          </details>
        ))}
      </div>
    </div>
  </section>

  <Testimonials />

  <ClientLogos
    eyebrow="Paid-media clients"
    title="Spending smart for brands like these"
    description="A snapshot of U.S. brands trusting PrintFast with their paid-media budget."
    background="muted"
  />

  <CTA
    eyebrow="Ready to Stop Wasting Ad Spend?"
    title="Let's Run PPC That Actually Pays You Back."
    description="Send us your current Google Ads or Meta ad spend and goals — our home service PPC team will respond with a no-nonsense PPC audit and cost-per-lead forecast within one business day. No contracts required to get started."
    primaryCta={{ label: 'Get My Free PPC Proposal', href: '/contact-us/' }}
    secondaryCta={{ label: 'Talk to a Paid-Media Strategist', href: '#contact' }}
  />

  <section id="contact" class="section">
    <div class="container-pf max-w-4xl">
      <ContactForm
        title="Talk to our paid-media team"
        subtitle="Share your current ad accounts and goals — we'll respond within one business day."
      />
    </div>
  </section>

  <style is:global>
    @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
    .animate-float { animation: float 5s ease-in-out infinite; }
    .delay-1 { animation-delay: 0.3s; }
    .delay-2 { animation-delay: 0.6s; }
  </style>
</BaseLayout>
