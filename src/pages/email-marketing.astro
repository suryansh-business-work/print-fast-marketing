---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import SectionHeading from '@components/SectionHeading.astro';
import FeatureGrid from '@components/FeatureGrid.astro';
import PricingCard from '@components/PricingCard.astro';
import Testimonials from '@components/Testimonials.astro';
import CTA from '@components/CTA.astro';
import ContactForm from '@components/ContactForm.astro';
import ClientLogos from '@components/ClientLogos.astro';

const capabilities = [
  { icon: 'fa-route',           title: 'Lifecycle automations',     description: 'Welcome series, post-purchase / post-job, win-back, abandoned cart and seasonal tune-up reminders.' },
  { icon: 'fa-newspaper',       title: 'Branded newsletters',       description: 'Weekly or monthly newsletters with a content calendar that mirrors your real promotions and seasonality.' },
  { icon: 'fa-list-check',      title: 'Segmentation & RFM',        description: 'Recency-frequency-monetary cohorts so the right offer hits the right customer at the right moment.' },
  { icon: 'fa-flask-vial',      title: 'A/B & multivariate testing', description: 'Subject lines, preview text, send times, creative and offers — tested with statistical confidence, not gut feel.' },
  { icon: 'fa-shield-check',    title: 'Deliverability engineering', description: 'SPF, DKIM, DMARC, BIMI, list hygiene and warm-up — the work that keeps you out of the Promotions tab and spam folder.' },
  { icon: 'fa-handshake-angle', title: 'CAN-SPAM & CASL compliance', description: 'Clear opt-out, accurate sender info, U.S. physical address and consent records — handled correctly from day one.' },
  { icon: 'fa-chart-line',      title: 'Revenue attribution',       description: 'Tie every send to revenue with first- and last-touch attribution, GA4 events and CRM sync.' },
];

const platforms = [
  { name: 'Klaviyo',         icon: 'fa-bolt' },
  { name: 'Mailchimp',       icon: 'fa-envelope' },
  { name: 'HubSpot',         icon: 'fa-cubes' },
  { name: 'ActiveCampaign',  icon: 'fa-circle-nodes' },
  { name: 'Constant Contact', icon: 'fa-envelopes-bulk' },
  { name: 'Customer.io',     icon: 'fa-user-gear' },
  { name: 'Salesforce MC',   icon: 'fa-cloud' },
  { name: 'ServiceTitan',    icon: 'fa-screwdriver-wrench' },
];

const stats = [
  { stat: '$36',  label: 'returned per $1 spent on email (DMA)' },
  { stat: '4.2%', label: 'average click-to-open rate across U.S. SMBs' },
  { stat: '60%',  label: 'of consumers prefer email for promos & offers' },
  { stat: '99%',  label: 'of email users check their inbox every day' },
];

const flows = [
  { icon: 'fa-hand-wave',          title: 'Welcome series',        desc: '3–5 emails over 10 days that introduce your brand, set expectations and convert first-time buyers.' },
  { icon: 'fa-rotate-right',       title: 'Post-job follow-up',    desc: 'Thank-you, review request and warranty info — automated 24, 48 hours and 30 days after service.' },
  { icon: 'fa-snowflake',          title: 'Seasonal tune-up',      desc: 'Heating-season, cooling-season and storm-prep reminders timed to your service area.' },
  { icon: 'fa-cart-shopping',      title: 'Quote / cart recovery', desc: 'Bring back people who got a quote or started checkout but never finished.' },
  { icon: 'fa-arrows-rotate',      title: 'Win-back & re-engagement', desc: 'Re-activate dormant subscribers with offer ladders before suppression.' },
  { icon: 'fa-cake-candles',       title: 'Loyalty & milestones',  desc: 'Birthday, anniversary and VIP tiers that quietly drive repeat revenue.' },
];

const plans = [
  {
    name: 'Foundations',
    price: '$749',
    description: 'Get a clean list, branded templates and the core automations live.',
    features: [
      'Audit + deliverability setup (SPF/DKIM/DMARC)',
      'Branded master template + 2 layouts',
      'Welcome + post-purchase / post-job flows',
      '2 newsletter sends per month',
      'Segmentation foundations',
      'Monthly performance report',
    ],
    cta: { label: 'Start with Foundations', href: '/contact-us/' },
  },
  {
    name: 'Growth',
    price: '$1,499',
    description: 'A working program with revenue we can prove.',
    popular: true,
    features: [
      'Everything in Foundations',
      '4 sends/month + 1 promotional broadcast',
      '6+ active automation flows',
      'Quarterly creative refresh',
      'Advanced segmentation & A/B tests',
      'Revenue attribution + GA4 reporting',
    ],
    cta: { label: 'Choose Growth', href: '/contact-us/' },
  },
  {
    name: 'Lifecycle',
    price: '$2,899',
    description: 'For brands ready to make email a top-3 revenue channel.',
    features: [
      'Everything in Growth',
      '8+ sends/month',
      'Custom RFM model & predictive flows',
      'CRM/ESP integration & sync',
      'Dedicated email strategist',
      'Bi-weekly review + custom dashboards',
    ],
    cta: { label: 'Build my lifecycle', href: '/contact-us/' },
  },
];

const faqs = [
  { q: 'Which email platform do you recommend?',
    a: 'It depends on your business. We work most often with Klaviyo (best for e-commerce and lifecycle), HubSpot (best for sales-led B2B) and Mailchimp/Constant Contact (best for simple newsletters). We will recommend the right tool, not the most expensive one.' },
  { q: 'Will my emails actually reach the inbox?',
    a: 'Deliverability is treated as a discipline here. We configure SPF, DKIM and DMARC, set up BIMI where eligible, warm new domains correctly and run continuous list hygiene. Most clients see inbox placement above 95% within 60 days.' },
  { q: 'Do you write the copy and design the emails?',
    a: 'Yes. Our team writes every send, designs every template and produces every image — all reviewed and approved by you before it goes out.' },
  { q: 'Who owns the list and the data?',
    a: 'You do. Lists, segments, templates and historical data live in your account and are exported to you on request, any time.' },
];
---

<BaseLayout
  title="Email Marketing Services in the USA"
  description="Email marketing services for U.S. businesses — lifecycle automations, newsletters and revenue attribution. CAN-SPAM compliant."
  keywords={[
    'email marketing services',
    'email marketing agency USA',
    'lifecycle email marketing',
    'Klaviyo agency',
    'Mailchimp services',
    'newsletter design and management',
    'CAN-SPAM compliance',
  ]}
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Email Marketing', href: '/email-marketing/' },
  ]}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Email Marketing',
    serviceType: 'Email Marketing',
    provider: { '@type': 'Organization', name: 'Print Fast Digital Marketing' },
    areaServed: { '@type': 'Country', name: 'United States' },
    offers: [
      { '@type': 'Offer', name: 'Foundations', price: '749',  priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Growth',      price: '1499', priceCurrency: 'USD' },
      { '@type': 'Offer', name: 'Lifecycle',   price: '2899', priceCurrency: 'USD' },
    ],
  }}
>
  <Hero
    variant="service"
    eyebrow="Email Marketing"
    title="Email that"
    highlight="quietly compound revenue."
    description="Done-for-you email programs — strategy, copy, design, automations and deliverability — engineered to become a top-three revenue channel for U.S. brands."
    primaryCta={{ label: 'Request a proposal', href: '/contact-us/' }}
    secondaryCta={{ label: 'See pricing', href: '#pricing' }}
  />

  <!-- Stats -->
  <section class="section-tight">
    <div class="container-pf">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {stats.map((s) => (
          <div class="card p-7 text-center" data-reveal>
            <p class="font-display text-4xl font-extrabold gradient-text">{s.stat}</p>
            <p class="mt-2 text-sm text-ink-600">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="What's included"
        title="A complete email program"
        description="Strategy, creative, automations and deliverability — managed by senior operators, not a junior account team."
      />
      <div class="mt-14">
        <FeatureGrid items={capabilities} columns={4} />
      </div>
    </div>
  </section>

  <!-- Flows -->
  <section class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="The automations we build"
        title="Six flows that pay for the program"
        description="These are the core lifecycle journeys we deploy on every account, then customize to your offer and seasonality."
      />
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {flows.map((f) => (
          <div class="card-hover p-7" data-reveal>
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-600 text-lg">
              <i class:list={['fa-solid', f.icon]}></i>
            </span>
            <h3 class="mt-5 text-lg font-bold text-ink-900">{f.title}</h3>
            <p class="mt-2 text-sm text-ink-600 leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Platforms -->
  <section class="section bg-ink-50/60">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Platforms we work in"
        title="Bring your stack — or let us recommend it"
        description="We are platform-agnostic and certified across the major U.S. ESPs and CRMs."
      />
      <ul class="mt-12 grid grid-cols-2 sm:grid-cols-4 gap-3">
        {platforms.map((p) => (
          <li class="flex flex-col items-center justify-center gap-3 rounded-2xl bg-white p-5 ring-1 ring-ink-100 hover:ring-brand-300 transition-all">
            <span class="grid h-12 w-12 place-items-center rounded-full bg-brand-50 text-brand-600 text-lg">
              <i class:list={['fa-solid', p.icon]}></i>
            </span>
            <span class="text-sm font-semibold text-ink-800 text-center">{p.name}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="section">
    <div class="container-pf">
      <SectionHeading
        eyebrow="Plans & pricing"
        title="Month-to-month pricing in USD"
        description="Pricing covers strategy, creative, deployment and reporting. Your ESP platform fees are billed by the platform directly."
      />
      <div class="mt-14 grid gap-6 lg:grid-cols-3">
        {plans.map((p) => <PricingCard {...p} />)}
      </div>
      <p class="mt-8 text-center text-sm text-ink-500">
        <span class="font-semibold text-brand-700">Save 10% on annual prepay.</span> List size up to 50,000 contacts; larger lists priced per send.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-ink-50/60">
    <div class="container-pf max-w-4xl">
      <SectionHeading eyebrow="FAQs" title="Common questions" />
      <div class="mt-10 space-y-3">
        {faqs.map((f) => (
          <details class="group card p-6 transition-colors hover:ring-brand-200">
            <summary class="flex cursor-pointer items-center justify-between gap-4 list-none">
              <span class="font-semibold text-ink-900">{f.q}</span>
              <i class="fa-solid fa-plus text-ink-400 group-open:rotate-45 transition-transform"></i>
            </summary>
            <p class="mt-4 text-ink-600 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Testimonials />

  <ClientLogos
    eyebrow="Trusted partners"
    title="Email programs we've built"
    description="A snapshot of the U.S. brands sending with Print Fast."
    background="muted"
  />

  <CTA
    eyebrow="Ready to send better email?"
    title="Let's make email a top revenue channel."
    description="Tell us about your list and goals — we'll send a 90-day plan and ROI projection within one business day."
    primaryCta={{ label: 'Request a proposal', href: '/contact-us/' }}
    secondaryCta={{ label: 'Talk to a strategist', href: '#contact' }}
  />

  <section id="contact" class="section">
    <div class="container-pf max-w-4xl">
      <ContactForm
        title="Talk to our email team"
        subtitle="Tell us about your current ESP and goals — we'll respond within one business day."
      />
    </div>
  </section>
</BaseLayout>
